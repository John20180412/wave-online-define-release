<?xml version="1.0" encoding="iso-8859-1"?>
<category name="NODE CONFIGURATION">
    <subcategory name="MAC Layer" class="interface,device,atmdevice">
        <variable name="Interface Name" key="DUMMY-INTERFACE-TYPE" type="Selection" default="SUBNET-WIRELESS" help="" visibilityrequires="false" keyvisible="false">
            <option name="Link Wireless" value="LINK-WIRELESS" />
            <option name="Subnet Wired" value="SUBNET-WIRED" />
            <option name="Link Microwave" value="LINK-MICROWAVE" />
            <option name="Subnet Wireless" value="SUBNET-WIRELESS" />
            <option name="Link Wired" value="LINK-WIRED" />
            <option name="Subnet Satellite" value="SUBNET-SATELLITE" />
        </variable>
        <variable name="Symmetric" key="DUMMY-GUI-SYMMETRIC-LINK" type="Checkbox" default="YES" help="" visibilityrequires="false" keyvisible="false"/>
        <variable name="MAC Protocol" key="LINK-MAC-PROTOCOL" type="Selection" default="ABSTRACT" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-WIRED' || [DUMMY-INTERFACE-TYPE] == 'LINK-WIRELESS' || [DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE'" disable="true" printable="false">
            <option value="ABSTRACT" name="Abstract Link MAC">
                <variable key="LINK-PROPAGATION-DELAY" type="Time" name="Link Propagation Delay" default="1MS" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-WIRED' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-PROPAGATION-SPEED" type="Fixed" name="Link Propagation Speed (m/s)" default="3e8" visibilityrequires="([DUMMY-INTERFACE-TYPE] == 'LINK-WIRELESS' || [DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE') &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'" optional="true" />
                <variable name="Bandwidth" key="LINK-BANDWIDTH" type="Fixed multiplier" default="10 Mbps" min="0 bps" unit="bps" visibilityrequires="[LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable name="Link Header Size (bits)" key="LINK-HEADER-SIZE-IN-BITS" type="Integer" default="224" min="0" visibilityrequires="[LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable name="Link Drop Probability" key="LINK-DROP-PROBABILITY" type="Fixed" default="0" min="0" max="1" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-WIRED' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-TX-FREQUENCY" name="Transmission Frequency" type="Fixed multiplier" default="13.17 GHz" unit="Hz" min="1 GHz" max="350 GHz" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-RX-FREQUENCY" name="Receiving Frequency" type="Fixed multiplier" default="13.17 GHz" unit="Hz" min="1 GHz" max="350 GHz" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-TX-ANTENNA-HEIGHT" name="Transmission Antenna Height (meters)" type="Fixed" default="30" min="3" max="200" help="Tx antenna height in meters." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-RX-ANTENNA-HEIGHT" name="Receiving Antenna Height (meters)" type="Fixed" default="30" min="3" max="200" help="Rx antenna height in meters." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-TX-ANTENNA-DISH-DIAMETER" name="Transmission Antenna Dish Diameter (meters)" type="Fixed" default="0.8" min="0.01" help="Tx antenna dish diameter in meters." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-RX-ANTENNA-DISH-DIAMETER" name="Receiving Antenna Dish Diameter (meters)" type="Fixed" default="0.8" min="0.01" help="Rx antenna dish diameter in meters." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-TX-ANTENNA-CABLE-LOSS" name="Transmission Antenna Cable Loss (dB)" type="Fixed" default="1.5" min="0" help="In practice it should be less than 20 dB." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-RX-ANTENNA-CABLE-LOSS" name="Receiving Antenna Cable Loss (dB)" type="Fixed" default="1.5" min="0" help="In practice it should be less than 20 dB." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-TX-ANTENNA-POLARIZATION" name="Transmission Antenna Polarization" type="Selection" default="VERTICAL" optional="true" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'">
                    <option value="HORIZONTAL" name="Horizontal" />
                    <option value="VERTICAL" name="Vertical" />
                </variable>
                <variable key="LINK-RX-ANTENNA-POLARIZATION" name="Receiving Antenna Polarization" type="Selection" default="VERTICAL" optional="true" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'">
                    <option value="HORIZONTAL" name="Horizontal" />
                    <option value="VERTICAL" name="Vertical" />
                </variable>
                <variable key="LINK-TX-POWER" name="Transmission Power (dBm)" type="Fixed" min="0" default="30" help="In practice it should be larger than 0 dBm." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-RX-SENSITIVITY" name="Receiving Sensitivity (dBm)" type="Fixed" default="-80" min="-90" max="-60" help="It should be larger than the noise power." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-NOISE-TEMPERATURE" name="Noise Temperature (K)" type="Integer" default="290" help="The larger noise temperature the higher noise power." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-NOISE-FACTOR" name="Noise Factor" type="Integer" default="4" min="1" help="The larger noise factor the higher noise power." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-TERRAIN-TYPE" name="Terrain Type" type="Selection" default="PLAINS" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'">
                    <option value="PLAINS" name="Plains" />
                    <option value="HILLS" name="Hills" />
                    <option value="MOUNTAINS" name="Mountains" />
                </variable>
                <variable key="LINK-PROPAGATION-RAIN-INTENSITY" name="Propagation Rain Intensity (mm/h)" type="Fixed" default="0" min="0" max="100" help="Refer to ITU-R.Recommendation P.837-1 to have rain intensity value for desired area." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-PROPAGATION-TEMPERATURE" name="Propagation Temperature (C)" type="Fixed" default="25" min="-20" max="50" help="In practice it should be in the range -20 to +50 Degrees Centigrade." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-PROPAGATION-SAMPLING-DISTANCE" name="Propagation Sampling Distance (meters)" type="Fixed" default="100" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-PROPAGATION-CLIMATE" name="Propagation Climate" type="Selection" default="1" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'">
                    <option value="1" name="Equatorial" />
                    <option value="2" name="Continental Subtropical" />
                    <option value="3" name="Maritime Tropical" />
                    <option value="4" name="Desert" />
                    <option value="5" name="Continental Temperate" />
                    <option value="6" name="Maritime Temperate, Over Land" />
                    <option value="7" name="Maritime Temperate, Over Sea" />
                </variable>
                <variable key="LINK-PROPAGATION-REFRACTIVITY" name="Propagation Refractivity" type="Selection" default="360" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'">
                    <option value="360" name="Equatorial" />
                    <option value="320" name="Continental Subtropical" />
                    <option value="370" name="Maritime Tropical" />
                    <option value="280" name="Desert" />
                    <option value="301" name="Continental Temperate" />
                    <option value="320" name="Maritime Temperate, Over Land" />
                    <option value="350" name="Maritime Temperate, Over Sea" />
                </variable>
                <variable key="LINK-PROPAGATION-PERMITTIVITY" name="Propagation Permittivity" type="Selection" default="15" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'">
                    <option value="15" name="Average Ground" />
                    <option value="4" name="Poor Ground" />
                    <option value="25" name="Good Ground" />
                    <option value="81" name="Fresh Water" />
                    <option value="81" name="Salt Water" />
                </variable>
                <variable key="LINK-PROPAGATION-CONDUCTIVITY" name="Propagation Conductivity" type="Selection" default="0.005" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'">
                    <option value="0.005" name="Average Ground" />
                    <option value="0.001" name="Poor Ground" />
                    <option value="0.02" name="Good Ground" />
                    <option value="0.01" name="Fresh Water" />
                    <option value="5.0" name="Salt Water" />
                </variable>
                <variable key="LINK-PROPAGATION-HUMIDITY" name="Propagation Humidity" type="Selection" default="50" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'">
                    <option value="50" name="Temperate Summer" />
                    <option value="80" name="Temperate Winter" />
                </variable>
                <variable key="LINK-PERCENTAGE-TIME-REFRACTIVITY-GRADIENT-LESS-STANDARD" name="Percentage Time Refractivity Gradient Less Standard" type="Integer" default="15" min="0" max="100" help="Refer to ITU-R Recommendation P.453-6 to have value for desired area." visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' &amp;&amp; [LINK-MAC-PROTOCOL] == 'ABSTRACT' &amp;&amp; [DUMMY-GUI-SYMMETRIC-LINK] == 'NO'"/>
                <variable key="LINK-GENERATE-AUTOMATIC-DEFAULT-ROUTE" name="Generate Automatic Default Route" type="Selection" default="YES" optional="true">
                        <option value="YES" name="Yes" />
                        <option value="NO" name="No" />
                </variable>
            </option>
            <option value="MAC802.3" name="802.3"/>
         </variable>

        <variable name="MAC Protocol" key="MAC-PROTOCOL" type="Selection" default="MACDOT11" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-SATELLITE' || [DUMMY-INTERFACE-TYPE] == 'SUBNET-ADVANCE-SATELLITE' || [DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRED' || [DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS' || [DUMMY-INTERFACE-TYPE] == 'ANE-SATELLITE'" refreshtable="true">
            <!--<option value="None" name="None"/>-->
            <option value="MAC802.3" name="802.3" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRED'">
                <variable name="802.3 Bandwidth" key="SUBNET-DATA-RATE" type="Selection" default="100000000">
                    <option value="10000000000" name="10 Gbps" />
                    <option value="1000000000" name="1 Gbps" />
                    <option value="100000000" name="100 Mbps" />
                    <option value="10000000" name="10 Mbps" />
                </variable>
                <variable name="802.3 Propagation Delay" key="SUBNET-PROPAGATION-DELAY" type="Time" default="2.5US" />
                <variable name="802.3 Mode" key="MAC802.3-MODE" type="Selection" default="HALF-DUPLEX">
                    <option value="HALF-DUPLEX" name="Half-Duplex" />
                    <option value="FULL-DUPLEX" name="Full-Duplex" />
                </variable>
                <variable name="802.3 Drop Probability" key="SUBNET-DROP-PROBABILITY" type="Fixed" default="0" min="0" max="1"/>
            </option>
            <option value="SWITCHED-ETHERNET" name="Switched Ethernet" addon="developer" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRED'">
                <variable name="Data Rate" key="SUBNET-DATA-RATE" type="Fixed multiplier" default="100 Mbps" unit="bps" />
                <variable name="Propagation Delay" key="SUBNET-PROPAGATION-DELAY" type="Time" default="5US" />
            </option>
            <option value="SATCOM" name="Abstract Satellite (SATCOM) MAC" addon="developer" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-SATELLITE'">
                <variable name="Satellite Node" key="SATCOM-SATELLITE-NODE" type="Integer" default="0" issatellitekey="yes" visibilityrequires="false" />
                <variable name="SATCOM Type" key="SATCOM-TYPE" type="Selection" default="BENT-PIPE" visibilityrequires="false">
                    <option value="BENT-PIPE" name="Bent Pipe" />
                </variable>
                <variable name="Bandwidth" key="SATCOM-BANDWIDTH" type="Fixed multiplier" default="1 Mbps" unit="bps" maxunit="Ebps" minunit="bps" />
                <variable name="Propagation Delay" key="SATCOM-PROPAGATION-DELAY" type="Time" default="270MS" />
            </option>
            <option value="MAC-BT-CLASSIC" name="Bluetooth Classic" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable key="BT-DATA-RATE" type="Selection" name="Data Rate" default="1000000" help="Data rates in bps. Supported data rates: 1 Mbps, 2 Mbps, 3 Mbps">
                    <option value="1000000" name="1 Mbps"/>
                    <option value="2000000" name="2 Mbps"/>
                    <option value="3000000" name="3 Mbps"/>
                </variable>
                <variable name="Device Type" key="BT-DEVICE-TYPE" type="Selection" default="SLAVE">
                    <option value="MASTER" name="Master">
                        <variable name="List of Paired Devices" key="BT-MASTER-PAIRED-DEVICES" type="NodeRange" default="[Optional]"/>
                        <variable name="Inquiry Timeout" key="BT-INQUIRY-TIMEOUT" type="Time" default="10.24S" min="1.28S"/>
                        <variable name="Page Timeout" key="BT-PAGE-TIMEOUT" type="Time" default="5.12S" min="1.28S"/>
                        <variable name="Connect Next Device Interval" key="BT-CONNECT-NEXT-INTERVAL" type="Time" default="10.24S" min="6S"/>
                    </option>
                    <option value="SLAVE" name="Slave">
                        <variable name="Page Scan Window" key="BT-PAGE-SCAN-WINDOW" type="Time" default="40MS" min="40MS"/>
                        <variable name="Page Scan Interval" key="BT-PAGE-SCAN-INTERVAL" type="Time" default="1.28S" min="40MS"/>
                    </option>
                </variable>
                <variable name="Connection Supervision Timeout" key="BT-DEVICE-SUPERVISION-TIMEOUT" type="Time" default="20S" min="20S"/>
                <variable name="Logical Transport Queue Size (bytes)" key="BT-MAC-LT-QUEUE-SIZE" type="Integer" default="1500000" min ="1000000"/>
            </option>

            <option value="MAC-BT-LE" name="Bluetooth Low Energy" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable key="BT-DATA-RATE" type="Selection" name="Data Rate" default="1000000" help="Data rates in bps. Supported data rates: 1 Mbps, 2 Mbps, 3 Mbps">
                    <option value="1000000" name="1 Mbps"/>
                    <option value="2000000" name="2 Mbps"/>
                </variable>
                <variable name="Device Type" key="BT-DEVICE-TYPE" type="Selection" default="ADVERTISER">
                    <option value="ADVERTISER" name="Advertiser">
                        <variable name="Advertising Interval" key="BT-LE-ADV-INTERVAL" type="Time" default="20MS" min="20MS"/>
                        <variable name="PDU Interval" key="BT-LE-PDU-INTERVAL" type="Time" default="1.25MS" min="625US" max="10MS"/>
                    </option>
                    <option value="SCANNER" name="Scanner">
                        <variable name="Scan Interval" key="BT-LE-SCAN-INTERVAL" type="Time" default="1S" max="40.96S"/>
                        <variable name="Scan Window" key="BT-LE-SCAN-WINDOW" type="Time" default="1S" max="40.96S"/>
                    </option>
                </variable>
                <variable name="Enable Primary Advertisement Channel 37" key="BT-LE-ENABLE-ADVERTISEMENT-CHANNEL-37" type="CheckBox" default="YES"/>
                <variable name="Enable Primary Advertisement Channel 38" key="BT-LE-ENABLE-ADVERTISEMENT-CHANNEL-38" type="CheckBox" default="YES"/>
                <variable name="Enable Primary Advertisement Channel 39" key="BT-LE-ENABLE-ADVERTISEMENT-CHANNEL-39" type="CheckBox" default="YES"/>
            </option>
            <option value="MACDOT11" name="802.11" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Short Packet Transmit Limit" key="MAC-DOT11-SHORT-PACKET-TRANSMIT-LIMIT" type="Integer" default="7" min="1" max="65535" />
                <variable name="Long Packet Transmit Limit" key="MAC-DOT11-LONG-PACKET-TRANSMIT-LIMIT" type="Integer" default="4" min="1" max="65535" />
                <variable name="RTS Threshold (bytes)" key="MAC-DOT11-RTS-THRESHOLD" type="Integer" default="0" min="0" max="2346" />
                <variable name="Stop Receiving after Header Mode" key="MAC-DOT11-STOP-RECEIVING-AFTER-HEADER-MODE" type="Checkbox" default="NO" />
                <variable name="Station Association Type" key="MAC-DOT11-ASSOCIATION" type="Selection" default="NONE" refreshtable="true">
                    <option value="NONE" name="None" >
                        <variable name="Enable Power Save Mode" key="MAC-DOT11-IBSS-SUPPORT-PS-MODE" type="Selection" default="NO" invisible="device,interface">
                            <option value="YES" name="Yes" >
                                <variable name="Beacon Start Time (TUs)" key="MAC-DOT11-IBSS-BEACON-START-TIME" type="Integer" default="[Optional]" min="1" max="65535" />
                                <variable name="Beacon Interval (TUs)" key="MAC-DOT11-IBSS-BEACON-INTERVAL" type="Integer" default="200" min="1" max="32767" />
                                <variable name="ATIM Duration (TUs)" key="MAC-DOT11-IBSS-PS-MODE-ATIM-DURATION" type="Integer" default="20" min="1" max="32767" />
                            </option>
                            <option value="NO" name="No" />
                        </variable>
                    </option>
                    <option value="DYNAMIC" name="Dynamic">
                        <variable name="SSID" key="MAC-DOT11-SSID" type="Text" default="SSID" />
                        <variable name="Set as Access Point" key="MAC-DOT11-AP" type="Selection" default="NO" invisible="scenariolevel, wiredsubnet" refreshtable="true">
                            <option value="NO" name="No" >
                                 <variable name="Station Scan Type" key="MAC-DOT11-SCAN-TYPE" type="Selection" default="DISABLED">
                                     <option value="DISABLED" name="Disabled" />
                                     <option value="PASSIVE" name="Passive" >
                                         <variable name="Configure Handover RSS Trigger" key="DUMMY-MAC-DOT11-STATION-HANDOVER-RSS-TRIGGER" type="Selection" default="NO" help="Set to Yes to configure Handover RSS Trigger Parameter" optional="true">
                                            <option value="NO" name="No" />
                                            <option value="YES" name="Yes">
                                                <variable name="Handover RSS Trigger (dBm)" key="MAC-DOT11-STATION-HANDOVER-RSS-TRIGGER" type="Fixed" default="-83.0" help="The STA will try to scan and re-associate with neighboring AP if the receiving signal strength (RSS) from serving AP is below this threshold" />
                                            </option>
                                         </variable>
                                     </option>
                                     <option value="ACTIVE" name="Active">
                                         <variable name="Max Channel Time (TUs)" key="MAC-DOT11-SCAN-MAX-CHANNEL-TIME" type="Integer" default="50" min="1" max="32767" optional="true"/>
                                         <variable name="Configure Handover RSS Trigger" key="DUMMY-MAC-DOT11-STATION-HANDOVER-RSS-TRIGGER" type="Selection" default="NO" help="Set to Yes to configure Handover RSS Trigger Parameter" optional="true">
                                            <option value="NO" name="No" />
                                            <option value="YES" name="Yes">
                                                <variable name="Handover RSS Trigger (dBm)" key="MAC-DOT11-STATION-HANDOVER-RSS-TRIGGER" type="Fixed" default="-83.0" help="The STA will try to scan and re-associate with neighboring AP if the receiving signal strength (RSS) from serving AP is below this threshold" />
                                            </option>
                                         </variable>
                                     </option>
                                 </variable>
                                 <variable name="Enable Power Save Mode" key="MAC-DOT11-STA-PS-MODE-ENABLE" type="Selection" default="NO" oldKey="MAC-DOT11-STA-PS-MODE-ENABLED">
                                     <option value="NO" name="No" />
                                     <option value="YES" name="Yes">
                                         <variable name="Listen Interval (beacon intervals)" key="MAC-DOT11-STA-PS-MODE-LISTEN-INTERVAL" type="Integer" default="10" min="1" max="32767" />
                                         <variable name="Listen to DTIM Frames" key="MAC-DOT11-STA-PS-MODE-LISTEN-DTIM-FRAME" type="Checkbox" default="YES"/>
                                     </option>
                                 </variable>
                                 <variable name="Enable PCF" key="DUMMY-MAC-DOT11-ENABLE-PCF" type="Selection" default="N/A" optional="true">
                                     <option value="N/A" name="No" />
                                     <option value="YES" name="Yes">
                                         <variable name="Station Poll Type" key="MAC-DOT11-STATION-POLL-TYPE" type="Selection" default="POLLABLE">
                                             <option value="POLLABLE" name="Pollable" />
                                             <option value="NOT-POLLABLE" name="Not Pollable" />
                                             <option value="POLLABLE-DONT-POLL" name="Don't Poll" />
                                         </variable>
                                         <variable name="Collect Station PCF Statistics" key="MAC-DOT11-STATION-PCF-STATISTICS" type="Checkbox" default="NO"/>
                                     </option>
                                 </variable>
                            </option>
                            <option value="YES" name="Yes">
                                <variable name="Station Scan Type" key="MAC-DOT11-SCAN-TYPE" type="Selection" default="DISABLED" visibilityrequires="false" help="This is just a dummy variable added such that during load/save this parameter is read if present" >
                                    <option value="DISABLED" name="Disabled" />
                                </variable>
                                <variable name="Beacon Start Time (TUs)" key="MAC-DOT11-BEACON-START-TIME" type="Integer" default="1" min="1" max="32767" optional="true"/>
                                <variable name="Beacon Interval (TUs)" key="MAC-DOT11-BEACON-INTERVAL" type="Integer" default="200" min="1" max="32767" />
                                <variable name="DTIM Period (beacon intervals)" key="MAC-DOT11-DTIM-PERIOD" type="Integer" default="3" min="1" max="255" />
                                <variable name="Relay Frames" key="MAC-DOT11-RELAY-FRAMES" type="Checkbox" default="YES"/>
                                <variable name="Enable Power Save Mode" key="MAC-DOT11-AP-SUPPORT-PS-MODE" type="Checkbox" default="NO" />
                                <variable name="Set as Point Coordinator" key="MAC-DOT11-PC" type="Selection" default="NO">
                                    <option value="NO" name="No" />
                                    <option value="YES" name="Yes">
                                        <variable name="CFP Repetition Interval (DTIM intervals)" key="MAC-DOT11-PC-CF-REPETITION-INTERVAL" type="Integer" default="1" min="1" max="9" />
                                        <variable name="CFP Duration (TUs)" key="MAC-DOT11-PC-CF-DURATION" type="Integer" default="50" min="1" max="32767" />
                                        <variable name="Delivery Mode" key="MAC-DOT11-PC-DELIVERY-MODE" type="Selection" default="POLL-AND-DELIVER">
                                            <option value="POLL-AND-DELIVER" name="Poll and Deliver" />
                                            <option value="POLL-ONLY" name="Poll Only" />
                                            <option value="DELIVER-ONLY" name="Deliver Only" />
                                        </variable>
                                        <variable name="Poll Save Mode" key="MAC-DOT11-PC-POLL-SAVE" type="Selection" default="BY-COUNT">
                                            <option value="BY-COUNT" name="By Count">
                                                <variable name="Minimum Count" key="MAC-DOT11-PC-POLL-SAVE-MIN" type="Integer" default="1" />
                                                <variable name="Maximum Count" key="MAC-DOT11-PC-POLL-SAVE-MAX" type="Integer" default="10" />
                                            </option>
                                            <option value="NONE" name="None" />
                                        </variable>
                                    </option>
                                </variable>
                            </option>
                        </variable>
                        <variable name="Set Mesh Parameters" key="DUMMY-MAC-DOT11-SET-MESH-PARAMETERS" type="Selection" default="NO" help="Set to Yes if device is an MP" invisible="ScenarioLevel, WiredSubnet" optional="true">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes" >
                                <variable name="Mesh ID" key="MAC-DOT11s-MESH-ID" type="Text" default="Mesh1" />
                                <variable name="Path Protocol" key="MAC-DOT11s-PATH-PROTOCOL" type="Selection" default="HWMP" help="Path protocol to use for route discovery / path selection" >
                                    <option value="HWMP" name="Hybrid Wireless Mesh Protocol" >
                                        <variable name="Active Route Timeout" key="MAC-DOT11s-HWMP-ACTIVE-ROUTE-TIMEOUT" type="Time" default="5S" help="Lifetime of an active route" />
                                        <variable name="My Route Timeout" key="MAC-DOT11s-HWMP-MY-ROUTE-TIMEOUT" type="Time" default="10S" help="Lifetime of a route when replied by destination" />
                                        <variable name="Reverse Route Timeout" key="MAC-DOT11s-HWMP-REVERSE-ROUTE-TIMEOUT" type="Time" default="5S" help="Lifetime of a route being discovered" />
                                        <variable name="Route Deletion Constant" key="MAC-DOT11s-HWMP-ROUTE-DELETION-CONSTANT" type="Integer" default="5" help="Constant used for route deletion" />
                                        <variable name="Route Discovery Type" key="MAC-DOT11s-HWMP-ROUTE-DISCOVERY-TYPE" type="Selection" default="EXPANDING-RING" help="Ad-hoc route discovery algorithm" >
                                            <option value="EXPANDING-RING" name="Expanding Ring" >
                                                <variable name="Initial RREQ TTL" key="MAC-DOT11s-HWMP-RREQ-TTL-INITIAL" type="Integer" default="2" help="Initial value of TTL in route requests" />
                                                <variable name="RREQ TTL Increment" key="MAC-DOT11s-HWMP-RREQ-TTL-INCREMENT" type="Integer" default="2" help="Increment to TTL in route requests retransmits" />
                                                <variable name="RREQ TTL Threshold" key="MAC-DOT11s-HWMP-RREQ-TTL-THRESHOLD" type="Integer" default="5" help="Value beyond which TTL is set to net diameter" />
                                                <variable name="Number of RREQ Attempts" key="MAC-DOT11s-HWMP-RREQ-MAX-TTL-ATTEMPTS" type="Integer" default="2" help="Number of attempts for an RREQ using maximum TTL" />
                                            </option>
                                            <option value="FULL-TTL" name="Full TTL">
                                                <variable name="Number of RREQ Attempts" key="MAC-DOT11s-HWMP-RREQ-MAX-TTL-ATTEMPTS" type="Integer" default="3" help="Number of attempts for a route request" />
                                            </option>
                                        </variable>
                                        <variable name="RREQs Replied by Destination Only" key="MAC-DOT11s-HWMP-RREQ-DESTINATION-ONLY" type="CheckBox" default="YES" help="Set to No if intermediate nodes can reply" />
                                        <variable name="Set Reply-and-forward Flag" key="MAC-DOT11s-HWMP-RREQ-REPLY-AND-FORWARD" type="CheckBox" default="YES" help="Set to No if intermediate nodes reply and forward request to destination" />
                                        <variable name="Set as a Mesh Point (MP)" key="MAC-DOT11s-MESH-POINT" type="Selection" default="NO" help="Set to Yes if device is an MP" invisible="ScenarioLevel, WiredSubnet, WirelessSubnet" refreshtable="true">
                                            <option value="NO" name="No" />
                                            <option value="YES" name="Yes" >
                                                <variable name="Set as Root MP" key="MAC-DOT11s-HWMP-ROOT" type="Selection" default="NO" help="Set to Yes if MP is a root for proactive routing" >
                                                    <option value="NO" name="No" />
                                                    <option value="YES" name="Yes" >
                                                        <variable name="Root Announcement Period" key="MAC-DOT11s-HWMP-ROOT-ANNOUNCEMENT-PERIOD" type="Time" default="4S" help="Interval between root announcements" />
                                                        <variable name="Registration Flag" key="MAC-DOT11s-HWMP-ROOT-REGISTRATION" type="CheckBox" default="YES" help="Set to No if paths from root to MPs are not created" />
                                                        <variable name="Lifetime of Path to Root " key="MAC-DOT11s-HWMP-ROOT-TIMEOUT" type="Time" default="10S" help="Lifetime of root announcements" />
                                                    </option>
                                                </variable>
                                                <variable name="Set as Mesh Portal Point (MPP)" key="MAC-DOT11s-MESH-PORTAL" type="Selection" default="NO" help="Set to Yes if MP is a portal to other subnets" >
                                                    <option value="NO" name="No" />
                                                    <option value="YES" name="Yes">
                                                        <variable name="Portal Announcement Period" key="MAC-DOT11s-PORTAL-ANNOUNCEMENT-PERIOD" type="Time" default="4S" help="Interval between periodic announcements by a mesh portal" />
                                                    </option>
                                                </variable>
                                            </option>
                                        </variable>
                                    </option>
                                </variable>
                                <variable name="Path Metric" key="MAC-DOT11s-PATH-METRIC" type="Selection" default="AIRTIME" help="Path metric to use for route/path costs" >
                                    <option value="AIRTIME" name="Airtime" />
                                </variable>
                                <variable name="Link Setup Rate Limit" key="MAC-DOT11s-LINK-SETUP-RATE-LIMIT" type="Integer" default="1" min="0" help="Maximum number of neighbor links to attempt per period" />
                                <variable name="Mesh Diameter (hops)" key="MAC-DOT11s-NET-DIAMETER" type="Integer" default="7" help="Maximum number of hops between MPs in a mesh" />
                                <variable name="Node Traversal Time" key="MAC-DOT11s-NODE-TRAVERSAL-TIME" type="Time" default="100MS" help="Conservative estimate of forwarding delay at MP" />
                                <variable name="Portal Timeout" key="MAC-DOT11s-PORTAL-TIMEOUT" type="Time" default="10S" help="Lifetime for announcements from mesh portals" />
                            </option>
                        </variable>
                    </option>
                </variable>
                <variable name="Enable Directional Antenna Mode" key="MAC-DOT11-DIRECTIONAL-ANTENNA-MODE" type="Selection" default="NO" visibilityrequires="false">
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="Direction Cache Expiration Time" key="MAC-DOT11-DIRECTION-CACHE-EXPIRATION-TIME" type="Time" default="2S" />
                        <variable name="NAV Delta Angle" key="MAC-DOT11-DIRECTIONAL-NAV-AOA-DELTA-ANGLE" type="Fixed" default="37.0" />
                        <variable name="Short Packet Limit" key="MAC-DOT11-DIRECTIONAL-SHORT-PACKET-TRANSMIT-LIMIT" type="Integer" default="8" />
                    </option>
                </variable>

                <variable name="Security Protocol" key="MAC-SECURITY-PROTOCOL" type="Selection" default="NO" help="Specify different authentication and encryption protocol for MAC-DOT11" addon="cyber">
                    <option value="NO" name="None" />
                    <option value="WEP" name="WEP">
                        <variable name="RC4 Encryption Delay" key="WEP-RC4-DELAY" type="Time" default="10US" min="0" max="1S" />
                        <variable name="Exclude Unencrypted" key="WEP-CCMP-ALLOW-UNENC" type="Checkbox" default="NO" />
                        <variable name="WEP Configuration File" key="WEP-CONFIG-FILE" type="File" default="[Required]" filetype="wep" />
                    </option>
                    <option value="CCMP" name="CCMP">
                        <variable name="AES Encryption Delay" key="CCMP-AES-DELAY" type="Time" default="10US" min="0" max="1S" />
                        <variable name="Exclude Unencrypted" key="WEP-CCMP-ALLOW-UNENC" type="Checkbox" default="NO" />
                        <variable name="CCMP Configuration File" key="CCMP-CONFIG-FILE" type="File" default="[Required]" filetype="ccmp"/>
                    </option>
                </variable>
                <variable name="Specify Network Security Parameters" key="WORMHOLE-VICTIM-COUNT-TURNAROUND-TIME" type="Selection" default="NO" addon="cyber">
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="Wormhole Victim Turnaround Time" key="WORMHOLE-VICTIM-TURNAROUND-TIME" type="Time" default="0MS" />
                    </option>
                </variable>
                <variable name="Database Control" key="DOT11-DATABASE-CONTROL" type="text" default="NONE" optional="true" />
            </option>
            <option value="MACDOT11e" name="802.11e" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Short Packet Transmit Limit" key="MAC-DOT11-SHORT-PACKET-TRANSMIT-LIMIT" type="Integer" default="7" min="1" max="65535" />
                <variable name="Long Packet Transmit Limit" key="MAC-DOT11-LONG-PACKET-TRANSMIT-LIMIT" type="Integer" default="4" min="1" max="65535" />
                <variable name="RTS Threshold" key="MAC-DOT11-RTS-THRESHOLD" type="Integer" default="0" min="0" max="2346" />
                <variable name="Enable HCCA" key="MAC-DOT11e-HCCA" type="Checkbox" default="NO"/>
                <variable name="Stop Receiving after Header Mode" key="MAC-DOT11-STOP-RECEIVING-AFTER-HEADER-MODE" type="Checkbox" default="NO" />
                <variable name="Station Association Type" key="MAC-DOT11-ASSOCIATION" type="Selection" default="NONE" refreshtable="true">
                    <option value="NONE" name="None" />
                    <option value="DYNAMIC" name="Dynamic">
                        <variable name="SSID" key="MAC-DOT11-SSID" type="Text" default="SSID" />
                        <variable name="Set as Access Point" key="MAC-DOT11-AP" type="Selection" default="NO" invisible="scenariolevel, wiredsubnet" refreshtable="true">
                            <option value="NO" name="No" >
                                <variable name="Station Scan Type" key="MAC-DOT11-SCAN-TYPE" type="Selection" default="DISABLED">
                                    <option value="DISABLED" name="Disabled" />
                                    <option value="PASSIVE" name="Passive" />
                                    <option value="ACTIVE" name="Active" />
                                </variable>
                            </option>
                            <option value="YES" name="Yes">
                                <variable name="Station Scan Type" key="MAC-DOT11-SCAN-TYPE" type="Selection" default="DISABLED" visibilityrequires="false" help="This is just a dummy variable added such that during load/save this parameter is read if present" >
                                    <option value="DISABLED" name="Disabled" />
                                </variable>
                                <variable name="Beacon Start Time (TUs)" key="MAC-DOT11-BEACON-START-TIME" type="Integer" default="1" min="1" max="65535" optional="true"/>
                                <variable name="Beacon Interval (TUs)" key="MAC-DOT11-BEACON-INTERVAL" type="Integer" default="200" min="1" max="32767" />
                                <variable name="Relay Frames" key="MAC-DOT11-RELAY-FRAMES" type="Checkbox" default="YES"/>
                                <variable name="Set as Hybrid Coordinator" key="MAC-DOT11e-HC" type="Selection" default="N/A" invisible="scenariolevel, wiredsubnet, wirelesssubnet">
                                    <option value="N/A" name="No" />
                                    <option value="YES" name="Yes">
                                        <variable name="802.11e CAP Limit" key="MAC-DOT11e-CAP-LIMIT" type="Integer" default="50" min="1" max="32767" />
                                    </option>
                                </variable>
                            </option>
                        </variable>
                        <variable name="Set Mesh Parameters" key="DUMMY-MAC-DOT11-SET-MESH-PARAMETERS" type="Selection" default="NO" help="Set to Yes if device is an MP" invisible="ScenarioLevel, WiredSubnet" optional="true">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes" >
                                <variable name="Mesh ID" key="MAC-DOT11s-MESH-ID" type="Text" default="Mesh1" />
                                <variable name="Path Protocol" key="MAC-DOT11s-PATH-PROTOCOL" type="Selection" default="HWMP" help="Path protocol to use for route discovery / path selection" >
                                    <option value="HWMP" name="Hybrid Wireless Mesh Protocol" >
                                        <variable name="Active Route Timeout" key="MAC-DOT11s-HWMP-ACTIVE-ROUTE-TIMEOUT" type="Time" default="5S" help="Lifetime of an active route" />
                                        <variable name="My Route Timeout" key="MAC-DOT11s-HWMP-MY-ROUTE-TIMEOUT" type="Time" default="10S" help="Lifetime of a route when replied by destination" />
                                        <variable name="Reverse Route Timeout" key="MAC-DOT11s-HWMP-REVERSE-ROUTE-TIMEOUT" type="Time" default="5S" help="Lifetime of a route being discovered" />
                                        <variable name="Route Deletion Constant" key="MAC-DOT11s-HWMP-ROUTE-DELETION-CONSTANT" type="Integer" default="5" help="Constant used for route deletion" />
                                        <variable name="Route Discovery Type" key="MAC-DOT11s-HWMP-ROUTE-DISCOVERY-TYPE" type="Selection" default="EXPANDING-RING" help="Ad-hoc route discovery algorithm" >
                                            <option value="EXPANDING-RING" name="Expanding Ring" >
                                                <variable name="Initial RREQ TTL" key="MAC-DOT11s-HWMP-RREQ-TTL-INITIAL" type="Integer" default="2" help="Initial value of TTL in route requests" />
                                                <variable name="RREQ TTL Increment" key="MAC-DOT11s-HWMP-RREQ-TTL-INCREMENT" type="Integer" default="2" help="Increment to TTL in route requests retransmits" />
                                                <variable name="RREQ TTL Threshold" key="MAC-DOT11s-HWMP-RREQ-TTL-THRESHOLD" type="Integer" default="5" help="Value beyond which TTL is set to net diameter" />
                                                <variable name="Number of RREQ Attempts" key="MAC-DOT11s-HWMP-RREQ-MAX-TTL-ATTEMPTS" type="Integer" default="2" help="Number of attempts for an RREQ using maximum TTL" />
                                            </option>
                                            <option value="FULL-TTL" name="Full TTL">
                                                <variable name="Number of RREQ Attempts" key="MAC-DOT11s-HWMP-RREQ-MAX-TTL-ATTEMPTS" type="Integer" default="3" help="Number of attempts for a route request" />
                                            </option>
                                        </variable>
                                        <variable name="RREQs Replied by Destination Only" key="MAC-DOT11s-HWMP-RREQ-DESTINATION-ONLY" type="CheckBox" default="YES" help="Set to No if intermediate nodes can reply" />
                                        <variable name="Set Reply-and-forward Flag" key="MAC-DOT11s-HWMP-RREQ-REPLY-AND-FORWARD" type="CheckBox" default="YES" help="Set to No if intermediate nodes reply and forward request to destination" />
                                        <variable name="Set as a Mesh Point (MP)" key="MAC-DOT11s-MESH-POINT" type="Selection" default="NO" help="Set to Yes if device is an MP" invisible="ScenarioLevel, WiredSubnet, WirelessSubnet" refreshtable="true">
                                            <option value="NO" name="No" />
                                            <option value="YES" name="Yes" >
                                                <variable name="Set as Root MP" key="MAC-DOT11s-HWMP-ROOT" type="Selection" default="NO" help="Set to Yes if MP is a root for proactive routing" >
                                                    <option value="NO" name="No" />
                                                    <option value="YES" name="Yes" >
                                                        <variable name="Root Announcement Period" key="MAC-DOT11s-HWMP-ROOT-ANNOUNCEMENT-PERIOD" type="Time" default="4S" help="Interval between root announcements" />
                                                        <variable name="Registration Flag" key="MAC-DOT11s-HWMP-ROOT-REGISTRATION" type="CheckBox" default="YES" help="Set to No if paths from root to MPs are not created" />
                                                        <variable name="Lifetime of Path to Root " key="MAC-DOT11s-HWMP-ROOT-TIMEOUT" type="Time" default="10S" help="Lifetime of root announcements" />
                                                    </option>
                                                </variable>
                                                <variable name="Set as Mesh Portal Point (MPP)" key="MAC-DOT11s-MESH-PORTAL" type="Selection" default="NO" help="Set to Yes if MP is a portal to other subnets" >
                                                    <option value="NO" name="No" />
                                                    <option value="YES" name="Yes">
                                                        <variable name="Portal Announcement Period" key="MAC-DOT11s-PORTAL-ANNOUNCEMENT-PERIOD" type="Time" default="4S" help="Interval between periodic announcements by a mesh portal" />
                                                    </option>
                                                </variable>
                                            </option>
                                        </variable>
                                    </option>
                                </variable>
                                <variable name="Path Metric" key="MAC-DOT11s-PATH-METRIC" type="Selection" default="AIRTIME" help="Path metric to use for route/path costs" >
                                    <option value="AIRTIME" name="Airtime" />
                                </variable>
                                <variable name="Link Setup Rate Limit" key="MAC-DOT11s-LINK-SETUP-RATE-LIMIT" type="Integer" default="1" min="0" help="Maximum number of neighbor links to attempt per period" />
                                <variable name="Mesh Diameter (hops)" key="MAC-DOT11s-NET-DIAMETER" type="Integer" default="7" help="Maximum number of hops between MPs in a mesh" />
                                <variable name="Node Traversal Time" key="MAC-DOT11s-NODE-TRAVERSAL-TIME" type="Time" default="100MS" help="Conservative estimate of forwarding delay at MP" />
                                <variable name="Portal Timeout" key="MAC-DOT11s-PORTAL-TIMEOUT" type="Time" default="10S" help="Lifetime for announcements from mesh portals" />
                            </option>
                        </variable>
                    </option>
                </variable>
                <variable name="Enable Directional Antenna Mode" key="MAC-DOT11-DIRECTIONAL-ANTENNA-MODE" type="Selection" default="NO" visibilityrequires="false">
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="Direction Cache Expiration Time" key="MAC-DOT11-DIRECTION-CACHE-EXPIRATION-TIME" type="Time" default="2S" />
                        <variable name="NAV Delta Angle" key="MAC-DOT11-DIRECTIONAL-NAV-AOA-DELTA-ANGLE" type="Fixed" default="37.0" />
                        <variable name="Packet Transmit Limit" key="MAC-DOT11-DIRECTIONAL-SHORT-PACKET-TRANSMIT-LIMIT" type="Integer" default="8" />
                    </option>
                </variable>
                <variable name="Enable U-APSD" key="MAC-DOT11-UAPSD-ENABLE" type="Selection" default="NO" visibilityrequires="([PHY-MODEL] == 'PHY802.11a' || [PHY-MODEL] == 'PHY802.11b' || [PHY-MODEL] == 'PHY802.11n' || [PHY-MODEL] == 'PHY802.11ac') &amp;&amp; [MAC-DOT11s-MESH-POINT] == 'NO'" refreshtable="true">
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="DTIM Period (beacon intervals)" key="MAC-DOT11-DTIM-PERIOD" type="Integer" default="3" min="1" max="255" visibilityrequires="[MAC-DOT11-AP] == 'YES'" refreshtable="true"/>
                        <variable name="Maximum Service Period Length" key="MAC-DOT11-MAX-SP-LENGTH" type="Selection" default="1" visibilityrequires="[MAC-DOT11-AP] == 'NO'" refreshtable="true">
                            <option value="0" name="0" />
                            <option value="1" name="1" />
                            <option value="2" name="2" />
                            <option value="3" name="3" />
                        </variable>
                        <variable name="Listen Interval (beacon intervals)" key="MAC-DOT11-STA-PS-MODE-LISTEN-INTERVAL" type="Integer" default="10" min="1" max="65535" visibilityrequires="[MAC-DOT11-AP] == 'NO'"/>
                        <variable name="Listen to DTIM Frames" key="MAC-DOT11-STA-PS-MODE-LISTEN-DTIM-FRAME" type="Checkbox" default="YES" visibilityrequires="[MAC-DOT11-AP] == 'NO'"/>
                    </option>
                </variable>
                
                <variable name="Specify Network Security Parameters" key="WORMHOLE-VICTIM-COUNT-TURNAROUND-TIME" type="Selection" default="NO" addon="cyber">
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="Wormhole Victim Turnaround Time" key="WORMHOLE-VICTIM-TURNAROUND-TIME" type="Time" default="0MS" />
                    </option>
                </variable>
                                <variable name="Database Control" key="DOT11-DATABASE-CONTROL" type="text" default="NONE" optional="true"/>
                <variable value="MACDOT11ac" name="Configure MAC 802.11ac Parameters" key="DUMMY-ENABLE-MACDOT11ac" type="Selection" default="NO" visibilityrequires="[PHY-MODEL] == 'PHY802.11ac'" keyvisible="false">
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="Reordering Buffer Timer" key="MAC-DOT11-REORDERING-BUFFER-TIMER-INTERVAL" type="Time" default="100MS" visibilityrequires="[PHY-MODEL] == 'PHY802.11ac'" />
                        <variable name="Queue Size per Destination (packets)" key="MAC-DOT11-QUEUE-SIZE-PER-DESTINATION" type="Integer" default="1000" min="1" max="150000"  />
                        <variable name="MPDU Length Index"  key="MAC-DOT11-MPDU-LENGTH-INDEX" type="Selection" default="0">
                            <option value="0" name="0" />
                            <option value="1" name="1" />
                            <option value="2" name="2" />
                        </variable>
                        <variable name="Enable AMSDUs" key="MAC-DOT11-AMSDU-ENABLE" type="Selection" default="NO">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="AMSDU Buffer Timer"  key="MAC-DOT11-AMSDU-BUFFER-TIMER-INTERVAL" type="Time" default="5MS" />
                            </option>
                        </variable>
                        <variable name="Enable AMPDUs" key="MAC-DOT11-AMPDU-ENABLE" type="Selection" default="NO">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="AMPDU Length Exponent" key="MAC-DOT11-AMPDU-LENGTH-EXPONENT" type="Selection" default="1" >
                                    <option value="0" name="0" />
                                    <option value="1" name="1" />
                                    <option value="2" name="2" />
                                    <option value="3" name="3" />
                                    <option value="4" name="4" />
                                    <option value="5" name="5" />
                                    <option value="6" name="6" />
                                    <option value="7" name="7" />
                                </variable>
                            </option>
                        </variable>
                        <variable name="Enable Spatial Multiplexing Power Save" key="MAC-DOT11-SMPS-MODE" type="selection" default="3" visibilityrequires="[MAC-DOT11s-MESH-POINT] == 'NO'">
                            <option value="0" name="Static" />
                            <option value="1" name="Dynamic" />
                            <option value="3" name="Disable" />
                        </variable>
                        <variable name="Enable VHT TxOP Power Save" key="MAC-DOT11-VHTTXOPPS-ENABLE" type="Selection" default="NO" visibilityrequires="[MAC-DOT11s-MESH-POINT] == 'NO'">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes" />
                        </variable>
                    </option>
                </variable>
                <variable value="MACDOT11ax" name="Configure MAC 802.11ax Parameters" key="DUMMY-ENABLE-MACDOT11ax" type="Selection" default="NO" visibilityrequires="[PHY-MODEL] == 'PHY802.11ax'" keyvisible="false">
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="Reordering Buffer Timer" key="MAC-DOT11-REORDERING-BUFFER-TIMER-INTERVAL" type="Time" default="100MS" visibilityrequires="[PHY-MODEL] == 'PHY802.11ax'" />
                        <variable name="Queue Size per Destination (packets)" key="MAC-DOT11-QUEUE-SIZE-PER-DESTINATION" type="Integer" default="1000" min="1" max="150000"  />
                        <variable name="MPDU Length Index"  key="MAC-DOT11-MPDU-LENGTH-INDEX" type="Selection" default="0">
                            <option value="0" name="0" />
                            <option value="1" name="1" />
                            <option value="2" name="2" />
                        </variable>
                        <variable name="Enable AMSDUs" key="MAC-DOT11-AMSDU-ENABLE" type="Selection" default="NO">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="AMSDU Buffer Timer"  key="MAC-DOT11-AMSDU-BUFFER-TIMER-INTERVAL" type="Time" default="5MS" />
                            </option>
                        </variable>
                        <variable name="Enable AMPDUs" key="MAC-DOT11-AMPDU-ENABLE" type="Selection" default="NO">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="AMPDU Length Exponent" key="MAC-DOT11-AMPDU-LENGTH-EXPONENT" type="Selection" default="1" >
                                    <option value="0" name="0" />
                                    <option value="1" name="1" />
                                    <option value="2" name="2" />
                                </variable>
                            </option>
                        </variable>
                        <variable name="Enable UL Scheduling" key="MAC-DOT11-ENABLE-UL-SCHEDULING" type="Selection" default="NO" visibilityrequires="[MAC-DOT11-AP] == 'YES'">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="Scheduling type" key="MAC-DOT11-UL-SCHEDULING-TYPE" type="Selection" default="OFDMA" >
                                    <option value="OFDMA" name="OFDMA">
                                        <variable name="OFDMA Scheduling Interval" key="MAC-DOT11-UL-OFDMA-SCHEDULING-INTERVAL" oldKey="MAC-DOT11-UL-SCHEDULING-INTERVAL" type="Time" default="5MS" min="1NS" />
                                    </option>
                                    <option value="MUMIMO" name="MU-MIMO">
                                        <variable name="MU-MIMO Scheduling Interval" key="MAC-DOT11-UL-MUMIMO-SCHEDULING-INTERVAL" type="Time" default="5MS" min="1NS" />
                                    </option>
                                    <option value="OFDMA,MUMIMO" name="OFDMA,MU-MIMO">
                                        <variable name="OFDMA Scheduling Interval" key="MAC-DOT11-UL-OFDMA-SCHEDULING-INTERVAL" oldKey="MAC-DOT11-UL-SCHEDULING-INTERVAL" type="Time" default="5MS" min="1NS" />
                                        <variable name="MU-MIMO Scheduling Interval" key="MAC-DOT11-UL-MUMIMO-SCHEDULING-INTERVAL" type="Time" default="5MS" min="1NS" />
                                    </option>
                               </variable>
                            </option>
                        </variable>
                        <variable name="Enable DL Scheduling" key="MAC-DOT11-ENABLE-DL-SCHEDULING" type="Selection" default="NO" visibilityrequires="[MAC-DOT11-AP] == 'YES'">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="Scheduling type" key="MAC-DOT11-DL-SCHEDULING-TYPE" type="Selection" default="OFDMA" >
                                    <option value="OFDMA" name="OFDMA">
                                        <variable name="OFDMA Scheduling Interval" key="MAC-DOT11-DL-OFDMA-SCHEDULING-INTERVAL" type="Time" default="5MS" min="1NS" />
                                    </option>
                                    <option value="MUMIMO" name="MU-MIMO">
                                        <variable name="MU-MIMO Scheduling Interval" key="MAC-DOT11-DL-MUMIMO-SCHEDULING-INTERVAL" type="Time" default="5MS" min="1NS" />
                                    </option>
                                    <option value="OFDMA, MUMIMO" name="OFDMA, MU-MIMO">
                                        <variable name="OFDMA Scheduling Interval" key="MAC-DOT11-DL-OFDMA-SCHEDULING-INTERVAL" type="Time" default="5MS" min="1NS" />
                                        <variable name="MU-MIMO Scheduling Interval" key="MAC-DOT11-DL-MUMIMO-SCHEDULING-INTERVAL" type="Time" default="5MS" min="1NS" />
                                    </option>
                                </variable>
                            </option>
                        </variable>
                    </option>
                </variable>
                <variable value="MACDOT11n" name="Configure MAC 802.11n Parameters" key="DUMMY-ENABLE-MACDOT11n" type="Selection" default="NO" visibilityrequires="[PHY-MODEL] == 'PHY802.11n'" keyvisible="false">
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="Enable Data Burst" key="DUMMY-HELP-MESSAGE" type="text" default="Set Radio Type to 802.11n Radio in the Physical Layer tab first." disable="true" keyvisible="false" visibilityrequires="[PHY-MODEL] != 'PHY802.11n'" />
                        <variable name="Input Buffer Timer Interval" key="DUMMY-HELP-MESSAGE" type="text" default="Set Radio Type to 802.11n Radio in the Physical Layer tab first." disable="true" keyvisible="false" visibilityrequires="[PHY-MODEL] != 'PHY802.11n'" />
                        <variable name="Queue Size per Destination (packets)" key="DUMMY-HELP-MESSAGE" type="text" default="Set Radio Type to 802.11n Radio in the Physical Layer tab first." disable="true" keyvisible="false" visibilityrequires="[PHY-MODEL] != 'PHY802.11n'" />
                        <variable name="Input Buffer Timer" key="MAC-DOT11-REORDERING-BUFFER-TIMER-INTERVAL" type="Time" default="100MS" visibilityrequires="[PHY-MODEL] == 'PHY802.11n'" oldKey="MAC-DOT11N-REORDERING-BUFFER-TIMER-INTERVAL"/>
                        <variable name="Queue Size per Destination (packets)" key="MAC-DOT11-QUEUE-SIZE-PER-DESTINATION" type="Integer" default="1000" min="1" max="65535" visibilityrequires="[PHY-MODEL] == 'PHY802.11n'" oldKey="MAC-DOT11N-QUEUE-SIZE-PER-DESTINATION" />
                        <variable name="Enable Data Burst" key="MAC-DOT11-ENABLE-DATA-BURSTING" type="Selection" default="NO" visibilityrequires="[PHY-MODEL] == 'PHY802.11n'" oldKey="MAC-DOT11N-ENABLE-DATA-BURSTING">
                            <option value="NO" name="No">
                                <variable name="Enable AMSDUs" key="MAC-DOT11-AMSDU-ENABLE" type="Selection" default="NO" oldKey="MAC-DOT11N-AMSDU-ENABLE">
                                    <option value="NO" name="No" />
                                    <option value="YES" name="Yes">
                                        <variable name="AMSDU Buffer Timer"  key="MAC-DOT11-AMSDU-BUFFER-TIMER-INTERVAL" type="Time" default="5MS" oldKey="MAC-DOT11N-AMSDU-BUFFER-TIMER-INTERVAL" />
                                        <variable name="Enable Big AMSDU" key="MAC-DOT11-ENABLE-BIG-AMSDU" type="Selection" default="NO" oldKey="MAC-DOT11N-ENABLE-BIG-AMSDU">
                                            <option value="NO" name="No" />
                                            <option value="YES" name="Yes"/>
                                        </variable>
                                    </option>
                                </variable>
                                <variable name="Enable AMPDUs" key="MAC-DOT11-AMPDU-ENABLE" type="Selection" default="NO" oldKey="MAC-DOT11N-AMPDU-ENABLE">
                                    <option value="NO" name="No" />
                                    <option value="YES" name="Yes">
                                        <variable name="AMPDU Length Exponent" key="MAC-DOT11-AMPDU-LENGTH-EXPONENT" type="Selection" default="1" oldKey="MAC-DOT11N-AMPDU-LENGTH-EXPONENT">
                                            <option value="0" name="0" />
                                            <option value="1" name="1" />
                                            <option value="2" name="2" />
                                            <option value="3" name="3" />
                                        </variable>
                                    </option>
                                </variable>
                            </option>
                            <option value="YES" name="Yes">
                                <variable name="Enable Delayed Block Acknowledgement" key="MAC-DOT11-ENABLE-DELAYED-BLOCK-ACK" type="Selection" default="NO" oldKey="MAC-DOT11N-ENABLE-DELAYED-BLOCK-ACK" >
                                    <option value="NO" name="No"/>
                                    <option value="YES" name="Yes"/>
                                </variable>
                                <variable name="Block Acknowledgement Policy Timeout" key="MAC-DOT11-BLOCK-ACK-POLICY-TIMEOUT" type="Time" default="500MS" oldKey="MAC-DOT11N-BLOCK-ACK-POLICY-TIMEOUT" />
                                <variable name="Enable RIFS Mode" key="MAC-DOT11-ENABLE-RIFS-MODE" type="Selection" default="NO" oldKey="MAC-DOT11N-ENABLE-RIFS-MODE">
                                    <option value="NO" name="No"/>
                                    <option value="YES" name="Yes"/>
                                </variable>
                            </option>
                        </variable>
                        <variable name="Enable Spatial Multiplexing Power Save" key="MAC-DOT11-SMPS-MODE" type="selection" default="3" visibilityrequires="[MAC-DOT11s-MESH-POINT] == 'NO'">
                            <option value="0" name="Static" />
                            <option value="1" name="Dynamic" />
                            <option value="3" name="Disable" />
                        </variable>
                    </option>
                </variable>
            </option>
            <option value = "MACDOT11p" name="802.11p" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Guard Interval Duration" key="MAC-802.11-GUARD-INTERVAL-DURATION" type ="Time" default="4MS"/>
                <variable name="CCH Interval Duration" key="MAC-802.11-CCH-INTERVAL-DURATION" type ="Time" default="50MS"/>
                <variable name="SCH Interval Duration" key="MAC-802.11-SCH-INTERVAL-DURATION" type ="Time" default="50MS"/>
            </option>
            <option value="MAC802.16" name="802.16" addon="advanced_wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Station Type" key="MAC-802.16-STATION-TYPE" type="Selection" default="SS">
                    <option value="SS" name="Subscriber Station">
                        <variable name="Wait DCD Timeout Interval" key="MAC-802.16-SS-WAIT-DCD-TIMEOUT-INTERVAL" type="Time" default="25S" />
                        <variable name="Wait UCD Timeout Interval" key="MAC-802.16-SS-WAIT-UCD-TIMEOUT-INTERVAL" type="Time" default="25S" />
                        <variable name="Service Flow Timeout Interval" key="MAC-802.16-SERVICE-FLOW-TIMEOUT-INTERVAL" type="Time" default="15S" />
                        <variable name="Enable Packing" key="MAC-802.16-PACKING-ENABLED" type="Checkbox" default="NO"/>
                        <variable name="Ranging Type" key="MAC-802.16-RANGING-TYPE" type="Selection" default="NORMAL">
                            <option value="NORMAL" name="Normal" />
                            <option value="CDMA" name="CDMA" />
                        </variable>
                        <variable name="Contention-based Bandwidth Request Type" key="MAC-802.16-CONTENTION-BASED-BWREQ-TYPE" type="Selection" default="NORMAL">
                            <option value="NORMAL" name="Normal" />
                            <option value="CDMA" name="CDMA" />
                        </variable>
                        <variable name="Enable Mobility Mode (802.16e)" key="MAC-802.16-SUPPORT-MOBILITY" type="Selection" default="NO">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="Neighbor BS Scanning RSS Trigger (dBm)" key="MAC-802.16e-NEIGHBOR-SCAN-RSS-TRIGGER" type="Fixed" default="-76.0" help="The SS will try to scan neighboring BSs if the receiving signal strength (RSS) from serving BS is below is threshold." />
                                <variable name="Handover RSS Trigger (dBm)" key="MAC-802.16e-HANDOVER-RSS-TRIGGER" type="Fixed" default="-78.0" help="The SS will try to start handover if the receiving signal strength (RSS) from serving BS is below is threshold." />
                                <variable name="Handover RSS Margin (dB)" key="MAC-802.16e-HANDOVER-RSS-MARGIN" type="Fixed" default="1.0" help="The SS will only handover to a target BS whose RSS level is higher than that of current serving BS no smaller than this margin." />
                                <variable name="Enable Sleep Mode" key="MAC-802.16e-SS-SUPPORT-SLEEP-MODE" type="Checkbox" default="NO"/>
                                <variable name="Enable Idle Mode" key="MAC-802.16e-SS-SUPPORT-IDLE-MODE" type="Checkbox" default="NO"/>
                            </option>
                        </variable>
                        <variable name="Enable ARQ" key="MAC-802.16-ARQ-ENABLED" type="Selection" default="NO">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="ARQ Window Size" key="MAC-802.16-ARQ-WINDOW-SIZE" type="Integer" default="256" min="1" max="1024" />
                                <variable name="ARQ Retry Timeout (frames)" key="MAC-802.16-ARQ-RETRY-TIMEOUT" type="Integer" default="4" min="0" max="1310700" help="If this parameter is 0, MAC-802.16-ARQ-RETRY-TIMEOUT value is considered infinite. The (MAC-802.16-ARQ-RETRY-TIMEOUT * frame duration) value must lie between 0 and (655350 * 2) micro seconds"/>
                                <variable name="ARQ Retry Count" key="MAC-802.16-ARQ-RETRY-COUNT" type="Integer" default="2" min="0" max="655350" />
                                <variable name="ARQ Sync Loss Interval (frames)" key="MAC-802.16-ARQ-SYNC-LOSS-INTERVAL" type="Integer" default="32" min="0" max="655350" help="If this parameter is 0, then ARQ sync loss value is considered infinite. The range of (this value * frame duration) is 0 to 655350 micro seconds"/>
                                <variable name="ARQ Receiving Purge Timeout Interval (frames)" key="MAC-802.16-ARQ-RX-PURGE-TIMEOUT" type="Time" default="28" min="0" max="655350" />
                                <variable name="ARQ Block Size (bytes)" key="MAC-802.16-ARQ-BLOCK-SIZE" type="Integer" default="64" min="1" max="2040" />
                            </option>
                        </variable>
                    </option>
                    <option value="BS" name="Base Station">
                        <variable name="MAC Frame Duration" key="MAC-802.16-BS-FRAME-DURATION" type="Time" default="20MS" />
                        <variable name="TDD Downlink Duration" key="MAC-802.16-BS-TDD-DL-DURATION" type="Time" default="10MS" />
                        <variable name="DCD Broadcast Interval" key="MAC-802.16-BS-DCD-BROADCAST-INTERVAL" type="Time" default="5S" />
                        <variable name="UCD Broadcast Interval" key="MAC-802.16-BS-UCD-BROADCAST-INTERVAL" type="Time" default="5S" />
                        <variable name="Ranging Minimal Backoff Value" key="MAC-802.16-BS-RANGING-BACKOFF-MIN" type="Integer" default="3" min="0" />
                        <variable name="Ranging Maximal Backoff Value" key="MAC-802.16-BS-RANGING-BACKOFF-MAX" type="Integer" default="15" min="0" />
                        <variable name="Bandwidth Request Minimal Backoff Value" key="MAC-802.16-BS-BANDWIDTH-REQUEST-BACKOFF-MIN" type="Integer" default="3" min="0" />
                        <variable name="Bandwidth Request Maximal Backoff Value" key="MAC-802.16-BS-BANDWIDTH-REQUEST-BACKOFF-MAX" type="Integer" default="15" min="0" />
                        <variable name="Service Flow Timeout Interval" key="MAC-802.16-SERVICE-FLOW-TIMEOUT-INTERVAL" type="Time" default="15S" />
                        <variable name="Transmit/Receive Transition Gap(TTG)" key="MAC-802.16-BS-TTG" type="Time" default="10US" />
                        <variable name="Receive/Transmit Transition Gap(RTG)" key="MAC-802.16-BS-RTG" type="Time" default="10US" />
                        <variable name="SS Transition Gap(SSTG)" key="MAC-802.16-BS-SSTG" type="Time" default="4US" />
                        <variable name="Maximum Allowed Uplink Load Level" key="MAC-802.16-MAX-ALLOWED-UPLINK-LOAD-LEVEL" type="Fixed" default="0.7" max="1" min="0" />
                        <variable name="Maximum Allowed Downlink Load Level" key="MAC-802.16-MAX-ALLOWED-DOWNLINK-LOAD-LEVEL" type="Fixed" default="0.7" max="1" min="0" />
                        <variable name="Enable Packing" key="MAC-802.16-PACKING-ENABLED" type="Checkbox" default="NO"/>
                        <variable name="Admission Control Scheme" key="MAC-802.16-BS-ADMISSION-CONTROL-SCHEME" type="Selection" default="NONE" >
                            <option value="NONE" name="None" />
                            <option value="BASIC" name="Basic" />
                        </variable>
                        <variable name="Ranging Type" key="MAC-802.16-RANGING-TYPE" type="Selection" default="NORMAL">
                            <option value="NORMAL" name="Normal" />
                            <option value="CDMA" name="CDMA" />
                        </variable>
                        <variable name="Contention-based Bandwidth Request Type" key="MAC-802.16-CONTENTION-BASED-BWREQ-TYPE" type="Selection" default="NORMAL">
                            <option value="NORMAL" name="Normal" />
                            <option value="CDMA" name="CDMA" />
                        </variable>
                        <variable name="Enable Mobility Mode (802.16e)" key="MAC-802.16-SUPPORT-MOBILITY" type="Selection" default="NO">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="Neighbor BS Scanning RSS Trigger (dBm)" key="MAC-802.16e-NEIGHBOR-SCAN-RSS-TRIGGER" type="Fixed" default="-76.0" help="The SS will try to scan neighboring BSs if the receiving signal strength (RSS) from serving BS is below is threshold." />
                                <variable name="Handover RSS Trigger (dBm)" key="MAC-802.16e-HANDOVER-RSS-TRIGGER" type="Fixed" default="-78.0" help="The SS will try to start handover if the receiving signal strength (RSS) from serving BS is below is threshold." />
                                <variable name="Handover RSS Margin (dB)" key="MAC-802.16e-HANDOVER-RSS-MARGIN" type="Fixed" default="1.0" help="The SS will only handover to a target BS whose RSS level is higher than that of current serving BS no smaller than this margin." />
                                <variable name="Neighbor BS List" key="MAC-802.16-BS-NEIGHBOR" type="String" default="{}" optional="true" help="A list of neighbor BSs for possiable handover, The neighbor BS list could be in the form of {nodeId1,nodeId2
} or {nodeId1 thru nodeId2} or a combination." />
                                <variable name="Configure Idle Mode Parameters" key="DUMMY-MAC-802.16e-BS-SUPPORT-IDLE-MODE" type="Selection" default="No" optional="true">
                                    <option value="NO" name="No" />
                                    <option value="YES" name="Yes">
                                        <variable name="Paging Group Id" key="MAC-802.16e-BS-PAGING-GROUP-ID" type="Integer" default="1" help="This parameter is used to divide the network in different paging groups. A BS may be part of one or more paging group" />
                                        <variable name="Configure as Paging Controller" key="MAC-802.16e-BS-IS-PAGING-CONTROLLER" type="Checkbox" default="No" help="This parameter is used for finding out whether Paging Controller is co-located with BS. There can only be one paging controller per network. There can be more than one network per simulation." />
                                        <variable name="Address of Paging Controller" key="MAC-802.16e-BS-PAGING-CONTROLLER" type="Text" default="[Required]" help="IP address of the Paging Controller which is responsible for carrying out paging related tasks for this BS "/>
                                        <variable name="Paging Interval (frames)" key="MAC-802.16e-BS-PAGING-INTERVAL-LENGTH" type="Integer" default="5" min="1" max="5" help="During this time, BS can send Paging Advertisement messages. The value is specified as number of frames."/>
                                        <variable name="Paging Cycle (frames)" key="MAC-802.16e-BS-PAGING-CYCLE" type="Integer" default="200" help="This is the cycle in which the paging message is transmitted within the paging group. The value is specified as number of frames."/>
                                        <variable name="Paging Offset (frames)" key="MAC-802.16e-BS-PAGING-OFFSET" type="Integer" default="5" help="Determines the frame within the cycle in which the paging message is transmitted. It must be smaller than PAGING CYCLE value. The value is specified as number of frames."/>
                                        <variable name="Paging Hashskip Threshold" key="MAC-802.16e-PAGING-HASHSKIP-THRESHOLD" type="Integer" default="0" min="0" max="255" help="This parameter is used for configuring the number of successive MOB-PAG-ADV messages that may be sent from a BS without individual notification for an MS."/>
                                    </option>
                                </variable>
                            </option>
                        </variable>
                        <variable name="Enable ARQ" key="MAC-802.16-ARQ-ENABLED" type="Selection" default="NO">
                            <option value="NO" name="No" />
                            <option value="YES" name="Yes">
                                <variable name="ARQ Window Size" key="MAC-802.16-ARQ-WINDOW-SIZE" type="Integer" default="256" min="1" max="1024" />
                                <variable name="ARQ Retry Timeout (frames)" key="MAC-802.16-ARQ-RETRY-TIMEOUT" type="Integer" default="4" min="0" max="1310700" help="If this parameter is 0, MAC-802.16-ARQ-RETRY-TIMEOUT value is considered infinite. The (MAC-802.16-ARQ-RETRY-TIMEOUT * frame duration) value must lie between 0 and (655350 * 2) micro seconds"/>
                                <variable name="ARQ Retry Count" key="MAC-802.16-ARQ-RETRY-COUNT" type="Integer" default="2" min="0" max="655350" />
                                <variable name="ARQ Sync Loss Interval (frames)" key="MAC-802.16-ARQ-SYNC-LOSS-INTERVAL" type="Integer" default="32" min="0" max="655350" help="If this parameter is 0, then ARQ sync loss value is considered infinite. The range of (this value * frame duration) is 0 to 655350 micro seconds"/>
                                <variable name="ARQ Receiving Purge Timeout Interval (frames)" key="MAC-802.16-ARQ-RX-PURGE-TIMEOUT" type="Time" default="28" min="0" max="655350" />
                                <variable name="ARQ Block Size (bytes)" key="MAC-802.16-ARQ-BLOCK-SIZE" type="Integer" default="64" min="1" max="2040" />
                            </option>
                        </variable>
                    </option>
                </variable>
            </option>
            <option value="MAC802.15.4" name="802.15.4" addon="sensor_networks" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Configure Thread Devices" key="MAC-802.15.4-CONFIGURE-THREAD-DEVICES" type="Selection" default="NO">
                    <option value="NO" name="No">
                        <variable name="Device Type" key="MAC-802.15.4-DEVICE-TYPE" type="Selection" default="RFD">
                            <option value="FFD" name="Full Function Device(FFD)">
                                <variable name="FFD Mode" key="MAC-802.15.4-FFD-MODE" type="Selection" default="PANCOORD">
                                    <option value="PANCOORD" name="PAN Coordinator">
                                        <variable name="Enable GTS" key="MAC-802.15.4-ENABLE-GTS" type="Selection" default="NO" invisible="wirelesssubnet">
                                            <option value="YES" name="Yes">
                                                <variable name="GTS Trigger Precedence" key="MAC-802.15.4-GTS-TRIGGER-PRECEDENCE" type="Integer" default="1" min="0" max="6" invisible="wirelesssubnet" help="CBR precedence that would implicitly trigger GTS request" />
                                            </option>
                                            <option value="NO" name="No" />
                                        </variable>
                                    </option>
                                    <option value="COORD" name="Coordinator" >
                                        <variable name="Poll Interval" key="MAC-802.15.4-POLL-INTERVAL" type="Time" default="1S" />
                                    </option>
                                    <option value="DEVICE" name="Device">
                                        <variable name="Poll Interval" key="MAC-802.15.4-POLL-INTERVAL" type="Time" default="1S" />
                                    </option>
                                </variable>
                            </option>
                            <option value="RFD" name="Reduced Function Device(RFD)">
                                <variable name="Poll Interval" key="MAC-802.15.4-POLL-INTERVAL" type="Time" default="1S" />
                            </option>
                        </variable>
                    </option>
                    <option value="YES" name="Yes">
                        <variable name="Device Type" key="MAC-802.15.4-DEVICE-TYPE" type="Selection" default="MTD">
                            <option value="FTD" name="Full Thread Device (FTD)">
                                <variable name="FTD Mode" key="MAC-802.15.4-FTD-MODE" type="Selection" default="LEADER">
                                    <option value="LEADER" name="Thread Leader">
                                        <variable name="Enable GTS" key="MAC-802.15.4-ENABLE-GTS" type="Selection" default="NO" invisible="wirelesssubnet">
                                            <option value="YES" name="Yes">
                                                <variable name="GTS Trigger Precedence" key="MAC-802.15.4-GTS-TRIGGER-PRECEDENCE" type="Integer" default="1" min="0" max="6" invisible="wirelesssubnet" help="CBR precedence that would implicitly trigger GTS request" />
                                            </option>
                                            <option value="NO" name="No" />
                                        </variable>
                                    </option>
                                    <option value="ROUTER" name="Router" >
                                        <variable name="Poll Interval" key="MAC-802.15.4-POLL-INTERVAL" type="Time" default="1S" />
                                    </option>
                                    <option value="FED" name="Full End Device (FED)">
                                        <variable name="Poll Interval" key="MAC-802.15.4-POLL-INTERVAL" type="Time" default="1S" />
                                    </option>
                                </variable>
                            </option>
                            <option value="MTD" name="Minimal Thread Device (MTD)">
                                <variable name="MTD Mode" key="MAC-802.15.4-MTD-MODE" type="Selection" default="SED">
                                    <option value="SED" name="Sleepy End Device (SED)">
                                        <variable name="Poll Interval" key="MAC-802.15.4-POLL-INTERVAL" type="Time" default="1S" />
                                    </option>
                                </variable>
                            </option>
                        </variable>
                    </option>
                </variable>
                <variable name="Enable Data Acknowledgements" key="MAC-802.15.4-ENABLE-DATA-ACKS" type="Selection" default="NO">
                    <option value="YES" name="Yes" />
                    <option value="NO" name="No" />
                </variable>
                <variable name="Beacon Order(the value of 15 disables beaconing)" key="MAC-802.15.4-COORD-BO" type="Integer" default="3" min="0" max="15"/>
                <variable name="SuperFrame Order" key="MAC-802.15.4-COORD-SO" type="Integer" default="3" min="0" max="15"/>
                <variable name="Device Starting Time" key="MAC-802.15.4-START-DEVICE-AT" type="Time" default="0S" />
                <variable name="Device Stopping Time" key="MAC-802.15.4-STOP-DEVICE-AT" type="Time" default="0S" />
            </option>
            <option value="GSM" name="GSM" addon="cellular" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="GSM Node Type" key="DUMMY-GSM-NODE-TYPE1" type="Text" default="Mobile Station" disable="true" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-MS'"  keyvisible="false"/>
                <variable name="GSM Node Type" key="DUMMY-GSM-NODE-TYPE2" type="Text" default="Base Station" disable="true" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" keyvisible="false"/>
                <variable name="GSM Node Type" key="DUMMY-GSM-NODE-TYPE3" type="Text" default="Mobile Switching Center" disable="true" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-MSC'" keyvisible="false"/>
                <variable name="GSM Control Channel List" key="GSM-CONTROL-CHANNEL-LIST" type="Text" default="[0]" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-MS'" help="MS's stored BCCH channel list, Format:[channelId1 ...channelIdn]."/>
                <variable name="BS Downlink Control Channel" key="GSM-CONTROL-CHANNEL" type="Text" default="[0]" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" help="Currently each BS uses the first (lowest  even numbered) channel alocated to it as the downlink control channel (C0). Format: [ChannelId]"/>
                <variable name="Location Area Code" key="DUMMY-GSM-LAC" type="Integer" default="1" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" keyvisible="false" />
                <variable name="Cell Identity" key="DUMMY-GSM-CELL-ID" type="Integer" default="1" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" keyvisible="false" />
                <variable name="Channel Range" key="DUMMY-GSM-CHANNEL-RANGE" type="ChannelRange" default="0-3" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" keyvisible="false" />
                <variable name="Neighboring Base Stations" key="DUMMY-GSM-NEIGHBOUR-BS" type="BsInfo" default="0-0-0" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" keyvisible="false" />
                <!--<variable name="GSM Node Type" key="GSM-NODE-TYPE" type="Selection" default="GSM-MS" invisible="scenariolevel">
                    <option value="GSM-MS" name="Mobile Station">
                        <variable name="GSM Control Channel List" key="GSM-CONTROL-CHANNEL" type="Text" default="[0]" help="MS's stored BCCH channel list, Format:[channelId1 ...channelIdn]."/>
                    </option>
                    <option value="GSM-BS" name="Base Station" >
                        <variable name="BS Downlink Control Channel" key="GSM-CONTROL-CHANNEL" type="Text" default="[0]" help="Currently each BS uses the first (lowest  even numbered) channel alocated to it as the downlink control channel (C0). Format: [ChannelId]"/>
                        <variable name="Location Area Code" key="DUMMY-GSM-LAC" type="Integer" default="1" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" keyvisible="false" />
                        <variable name="Cell Identity" key="DUMMY-GSM-CELL-ID" type="Integer" default="1" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" keyvisible="false" />
                        <variable name="Channel Range" key="DUMMY-GSM-CHANNEL-RANGE" type="ChannelRange" default="0-3" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" keyvisible="false" />
                        <variable name="Neighboring Base Stations" key="DUMMY-GSM-NEIGHBOUR-BS" type="BsInfo" default="0-0-0" visibilityrequires="[GSM-NODE-TYPE] == 'GSM-BS'" keyvisible="false" />
                    </option>
                    <option value="GSM-MSC" name="Mobile Switching Center" />
                </variable>-->
            </option>
            <option value="CELLULAR-MAC" name="Cellular MAC" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'" addon="cellular, umts">
                <variable name="Cellular MAC Protocol" key="CELLULAR-MAC-PROTOCOL" type="Selection" default="UMTS-LAYER2">
                    <option value="UMTS-LAYER2" name="UMTS Layer 2" addon="umts"/>
                    <option value="ABSTRACT-MAC" name="Abstract Cellular MAC" addon="cellular"/>
                </variable>
            </option>
            <option value="MAC-LTE" name="LTE MAC" addon="lte" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Number of Subframes per TTI" key="MAC-LTE-NUM-SF-PER-TTI" help="Corresponds to the TTI length." type="Selection" default="1" >
                    <option value="1" name="1" />
                    <option value="10" name="10" />
                </variable>
                <variable name="Station Type" key="MAC-LTE-STATION-TYPE" type="Selection" default="UE" invisible="device" keyvisible="true">
                    <option value="eNB" name="evolved Node B">
                        <variable key="RRC-LTE-MEAS-FILTER-COEFFICIENT" name="RRC : Measurement Filtering Coefficient" help="L3 filtering coefficient" type="Fixed" default="40" min="0" />

                        <variable key="RLC-LTE-MAX-RETX-THRESHOLD" name="RLC : Max Retransmission Threshold" help="Correspond to maxRetxThreshold in 3GPP document" type="Integer" default="8" min="0" />
                        <variable key="RLC-LTE-POLL-PDU" name="RLC : Threshold Number of PDUs for Polling" help="Correspond to pollPDU in 3GPP document" type="Integer" default="16" min="0" />
                        <variable key="RLC-LTE-POLL-BYTE" name="RLC : Threshold Number of Bytes for Polling" help="Correspond to pollBYTE in 3GPP document" type="Integer" default="250" min="0" />
                        <variable key="RLC-LTE-T-POLL-RETRANSMIT" name="RLC : t-PollRetransmit Timer Period" type="Time" default="100MS" min="1MS" />
                        <variable key="RLC-LTE-T-REORDERING" name="RLC : t-Reordering Timer Period" type="Time" default="100MS" min="1MS" />
                        <variable key="RLC-LTE-T-STATUS-PROHIBIT" name="RLC : t-StatusProhibit Timer Period" type="Time" default="12MS" min="1MS" />

                        <variable key="MAC-LTE-RA-BACKOFF-TIME" name="MAC : Backoff Period" type="Time" default="10MS" />
                        <variable key="MAC-LTE-RA-PREAMBLE-INITIAL-RECEIVED-TARGET-POWER" name="MAC : Initial Received Target Power for Preamble (dBm)" help="Correspond to preambleInitialReceivedTargetPower (dBm) in 3GPP document" type="Fixed" default="-90" max="1000" min="-1000" />
                        <variable key="MAC-LTE-RA-POWER-RAMPING-STEP" name="MAC : Power Ramping Step (dB)" help="Corresond to powerRampingStep (dB) in 3GPP document" type="Fixed" default="2" max="1000" min="0" />
                        <variable key="MAC-LTE-RA-PREAMBLE-TRANS-MAX" name="MAC : Maximum Number of Preamble Retransmissions" help="Correspond to preambleTransMax in 3GPP document" type="Integer" default="4" min="0" />
                        <variable key="MAC-LTE-RA-RESPONSE-WINDOW-SIZE" name="MAC : RA Response Window Size (subframes)" help="Correspond to ra-ResponseWindowSize in 3GPP document" type="Integer" default="10" min="3" />
                        <variable key="MAC-LTE-RA-PRACH-CONFIG-INDEX" name="MAC : PRACH Configuration Index" type="Integer" default="14" max="14" min="3" />
                        <variable key="MAC-LTE-PERIODIC-BSR-TTI" name="MAC : Periodic BSR Timer (TTI)" type="Integer" default="1" min="1" />
                        <variable key="MAC-LTE-ENB-SCHEDULER-TYPE" name="MAC : eNB Scheduler Type" type="Selection" default="ROUND-ROBIN">
                          <option value="ROUND-ROBIN" name="Round Robin" />
                          <option value="PROPORTIONAL-FAIRNESS" name="Proportional Fairness" />
                        </variable>
                        <variable key="MAC-LTE-TRANSMISSION-MODE" name="MAC : Transmission Mode" type="Selection" default="1">
                          <option value="1" name="Single Antenna Scheme" />
                          <option value="2" name="Transmission Diversity (SFBC)" />
                          <option value="3" name="Transmission Diversity / Open Loop Spatial Multiplexing" />
                        </variable>
                        <variable key="MAC-LTE-PF-FILTER-COEFFICIENT" name="MAC : PF Filter Coefficient" help="Exponential moving average coefficient for instant datarate" type="Fixed" default="36" min="0.0" />
                        <variable key="MAC-LTE-PF-UL-RB-ALLOCATION-UNIT" name="MAC : PF Scheduler UL RB Allocation Unit" help="Resource block allocation unit for UL PF scheduling" type="Integer" default="1" max="100" min="1" />
                        <variable key="MAC-LTE-MAX-HARQ-TX" name="MAC : Maximum Number of HARQ Transmissions" help="Maximum number of HARQ transmissions including first-transmission" type="Integer" default="4" max="4" min="1" />
                        <variable key="MAC-LTE-ENB-IS-5G-AWARE" name="MAC : 5G Aware eNB" type="Selection" default="NO" addon="5g">
                            <option value="YES" name="Yes"/>
                            <option value="NO" name="No"/>
                        </variable>
                    </option>
                    <option value="UE" name="User Equipment">
                        <variable key="RRC-LTE-WAIT-RRC-CONNECTED-TIME" name="RRC : Wait Time before RRC Connected Status" type="Time" default="10MS" />
                        <variable key="RRC-LTE-WAIT-RRC-CONNECTED-RECONF-TIME" name="RRC : Wait Time before RRC Reconfiguration" type="Time" default="10MS" />
                        <variable key="MAC-LTE-ENABLE-WIFI-SWITCHOVER" name="Enable Switch-overs between LTE and Wi-Fi" type="Selection" default="NO">
                            <option value="YES" name="Yes">
                                <variable key="MAC-LTE-SWITCH-CNTRL-HYSTERESIS-DELAY" name="Minimum Time between LTE/Wi-Fi Switch-overs" type="Time" default="1S" />
                            </option>
                            <option value="NO" name="No" />
                        </variable>
                        <variable key="MAC-LTE-UE-SCHEDULER-TYPE" name="MAC : UE Scheduler Type" type="Selection" default="SIMPLE-SCHEDULER">
                          <option value="SIMPLE-SCHEDULER" name="Simple Scheduler"/>
                        </variable>
                        <variable key="MAC-LTE-UE-ENABLE-DUAL-CONNECTIVITY" name="MAC : UE Support Dual Connectivity" type="Selection" default="NO" addon="5g">
                            <option value="YES" name="Yes"/>
                            <option value="NO" name="No"/>
                        </variable>
                    </option>
                </variable>

                <!-- Subnet-wide parameters -->
                <variable key="DUMMY-LTE-SPECIFY-MEASUREMENT-PARAMETERS" name="Specify Measurement Parameters" type="Selection" default="NO" invisible="device,interface">
                <option value="YES" name="YES">
                    <variable name="RRC : Events for RSRP Metric Handover Report" key="RRC-LTE-MEAS-OBSERVING-EVENT-MASK-RSRP" type="Selection" default="00000" help="A digit means an event type (from left to right, A1, A2, ..., A5.) Specify events as '1' observed by measurement function in RSRP metric." invisible="interface,device">
                        <option value="00000" name="No Events Observed" />
                        <option value="00100" name="Observe A3 Event" />
                    </variable>
                    <variable name="RRC : Events for RSRQ Metric Handover Report" key="RRC-LTE-MEAS-OBSERVING-EVENT-MASK-RSRQ" type="Selection" default="00000" help="A digit means an event type (from left to right, A1, A2, ..., A5.) Specify events as '1' observed by measurement function in RSRQ metric." invisible="interface,device">
                        <option value="00000" name="No Events Observed" />
                        <option value="00100" name="Observe A3 Event" />
                    </variable>

                    <!-- "Event A1", "Event A2", "Event A4" and "Event A5" should not be shown in GUI because these configuration parameters are disabled for future use.-->
                    <!--"Event A1"-->
                    <variable name="RRC : Threshold of Event A1 (RSRP) (dBm)" key="RRC-LTE-MEAS-EVENT-A1-RSRP-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A1 (RSRP) (dB)" key="RRC-LTE-MEAS-EVENT-A1-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold of Event A1 (RSRQ) (dBm)" key="RRC-LTE-MEAS-EVENT-A1-RSRQ-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A1 (RSRQ) (dB)" key="RRC-LTE-MEAS-EVENT-A1-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <!--"Event A2"-->
                    <variable name="RRC : Threshold of Event A2 (RSRP) (dBm)" key="RRC-LTE-MEAS-EVENT-A2-RSRP-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A2 (RSRP) (dB)" key="RRC-LTE-MEAS-EVENT-A2-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold of Event A2 (RSRQ) (dBm)" key="RRC-LTE-MEAS-EVENT-A2-RSRQ-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A2 (RSRQ) (dB)" key="RRC-LTE-MEAS-EVENT-A2-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <!--Only "Event A3" is enabled-->
                    <variable name="RRC : Offset of Event A3 (RSRP) (dB)" key="RRC-LTE-MEAS-EVENT-A3-RSRP-OFF" type="Fixed" default="0.0" min="-1000" max="1000"  invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A3 (RSRP) (dB)" key="RRC-LTE-MEAS-EVENT-A3-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000"  invisible="interface,device"/>
                    <variable name="RRC : Offset of Event A3 (RSRQ) (dB)" key="RRC-LTE-MEAS-EVENT-A3-RSRQ-OFF" type="Fixed" default="0.0" min="-1000" max="1000"  invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A3 (RSRQ) (dB)" key="RRC-LTE-MEAS-EVENT-A3-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000"  invisible="interface,device"/>
                    <!--"Event A4"-->
                    <variable name="RRC : Threshold of Event A4 (RSRP) (dBm)" key="RRC-LTE-MEAS-EVENT-A4-RSRP-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A4 (RSRP) (dB)" key="RRC-LTE-MEAS-EVENT-A4-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold of Event A4 (RSRQ) (dBm)" key="RRC-LTE-MEAS-EVENT-A4-RSRQ-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A4 (RSRQ) (dB)" key="RRC-LTE-MEAS-EVENT-A4-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <!--"Event A5"-->
                    <variable name="RRC : Threshold1 of Event A5 (RSRP) (dBm)" key="RRC-LTE-MEAS-EVENT-A5-RSRP-TH1" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold2 of Event A5 (RSRP) (dBm)" key="RRC-LTE-MEAS-EVENT-A5-RSRP-TH2" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A5 (RSRP) (dB)" key="RRC-LTE-MEAS-EVENT-A5-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold1 of Event A5 (RSRQ) (dBm)" key="RRC-LTE-MEAS-EVENT-A5-RSRQ-TH1" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold2 of Event A5 (RSRQ) (dBm)" key="RRC-LTE-MEAS-EVENT-A5-RSRQ-TH2" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A5 (RSRQ) (dB)" key="RRC-LTE-MEAS-EVENT-A5-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Time to Trigger Measurement Report Process" key="RRC-LTE-MEAS-TIME-TO-TRIGGER" type="Time" default="400MS" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Periodic Measurement Report Interval" key="RRC-LTE-MEAS-REPORT-INTERVAL" type="Time" default="120MS" invisible="interface,device"/>
                    <variable name="RRC : Number of Measurement Reports Sent" key="RRC-LTE-MEAS-REPORT-AMOUNT" type="Integer" default="1" min="1" invisible="interface,device"/>
                    <variable name="RRC : Coefficient of Filter Measured RSRP Value" key="RRC-LTE-MEAS-QUANTITY-CONFIG-FILTER-COEF-RSRP" type="Integer" default="4" min="0" max="100" invisible="interface,device"/>
                    <variable name="RRC : Coefficient of Filter Measured RSRQ Value" key="RRC-LTE-MEAS-QUANTITY-CONFIG-FILTER-COEF-RSRQ" type="Integer" default="4" min="0" max="100" invisible="interface,device"/>
                    <variable name="RRC : Type of Measurement Gap" key="RRC-LTE-MEAS-GAP-CONFIG-TYPE" type="Selection" default="0" help="Frequency of Inter-freq Measurement Is Determined by This Value." invisible="interface,device">
                        <option value="0" name="Every 40 subframes" />
                        <option value="1" name="Every 80 subframes" />
                    </variable>
                    <variable name="RRC : Subframe Offset of Inter-freq Measurement" key="RRC-LTE-MEAS-GAP-CONFIG-OFFSET" type="Integer" default="0" min="0" visibilityrequires="false" keyvisible="true"  invisible="interface,device"/>
                </option>
                    <option value="NO" name="NO" />
                </variable>

            </option>

            <option value="MAC-NR" name="NR MAC" addon="5g" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Number of Subframes per TTI" key="MAC-NR-NUM-SF-PER-TTI" help="Corresponds to the TTI length." type="Selection" default="1" >
                    <option value="1" name="1" />
                    <option value="10" name="10" />
                </variable>
                <variable name="Mode of Operation" key="MAC-NR-MODE" type="Selection" default="SA" invisible="device" keyvisible="true" refreshtable="true">
                    <option name="Non-Standalone" value="NSA"/>
                    <option name="Standalone" value="SA"/>
                </variable>
                <variable name="Station Type" key="MAC-NR-STATION-TYPE" type="Selection" default="UE" invisible="device" keyvisible="true">
                    <option value="gNB" name="5G Node B">
                        <variable name="Duplex Mode" key="MAC-NR-DUPLEX-MODE" type="Selection" default="FDD"
                        invisible="device" keyvisible="true" visibilityrequires="[MAC-NR-MODE]=='SA'" refreshtable="true">
                            <option name="FDD" value="FDD"/>
                            <option name="TDD" value="TDD">
                                <variable name="Number of Slot Configurations" key="MAC-NR-TDD-NUM-SLOT-CONFIG" type="Integer" default="3" invisible="device" keyvisible="true" disable="true" />
                                <variable name="Slot Configuration" key="MAC-NR-TDD-SLOT-CONFIG" type="Selection" default="MIXED" invisible="device" keyvisible="true">
                                    <option name="DL-Heavy" value="DL-HEAVY"/>
                                    <option name="Mixed" value="MIXED"/>
                                    <option name="UL-Heavy" value="UL-HEAVY"/>
                                </variable>
                                <variable name="Numerology" key="MAC-NR-TDD-NUMEROLOGY" type="Selection" default="0" invisible="device" keyvisible="true">
                                    <option name="0" value="0"/>
                                    <option name="1" value="1"/>
                                    <option name="2" value="2"/>
                                    <option name="3" value="3"/>
                                </variable>
                            </option>
                        </variable>
                        <variable key="RRC-NR-MEAS-FILTER-COEFFICIENT" name="RRC : Measurement Filtering Coefficient" help="L3 filtering coefficient" type="Fixed" default="40" min="0" />
                        <variable key="RLC-NR-MAX-RETX-THRESHOLD" name="RLC : Max Retransmission Threshold" help="Correspond to maxRetxThreshold in 3GPP document" type="Integer" default="8" min="0" />
                        <variable key="RLC-NR-POLL-PDU" name="RLC : Threshold Number of PDUs for Polling" help="Correspond to pollPDU in 3GPP document" type="Integer" default="16" min="0" />
                        <variable key="RLC-NR-POLL-BYTE" name="RLC : Threshold Number of Bytes for Polling" help="Correspond to pollBYTE in 3GPP document" type="Integer" default="250" min="0" />
                        <variable key="RLC-NR-T-POLL-RETRANSMIT" name="RLC : t-Poll Retransmit Timer Period" type="Time" default="100MS" min="1MS" />
                        <variable key="RLC-NR-T-REORDERING" name="RLC : t-Reordering Timer Period" type="Time" default="100MS" min="1MS" />
                        <variable key="RLC-NR-T-STATUS-PROHIBIT" name="RLC : t-Status Prohibit Timer Period" type="Time" default="12MS" min="1MS" />
                        <variable key="MAC-NR-RA-BACKOFF-TIME" name="MAC : Backoff Period" type="Time" default="10MS" />
                        <variable key="MAC-NR-RA-PREAMBLE-INITIAL-RECEIVED-TARGET-POWER" name="MAC : Initial Received Target Power for Preamble (dBm)" help="Correspond to preambleInitialReceivedTargetPower (dBm) in 3GPP document" type="Fixed" default="-90" max="1000" min="-1000" />
                        <variable key="MAC-NR-RA-POWER-RAMPING-STEP" name="MAC : Power Ramping Step (dB)" help="Corresond to powerRampingStep (dB) in 3GPP document" type="Fixed" default="2" max="1000" min="0" />
                        <variable key="MAC-NR-RA-PREAMBLE-TRANS-MAX" name="MAC : Maximum Number of Preamble Retransmissions" help="Correspond to preambleTransMax in 3GPP document" type="Integer" default="4" min="0" />
                        <variable key="MAC-NR-RA-RESPONSE-WINDOW-SIZE" name="MAC : RA Response Window Size (subframes)" help="Correspond to ra-ResponseWindowSize in 3GPP document" type="Integer" default="10" min="3" />
                        <variable key="MAC-NR-RA-PRACH-CONFIG-INDEX" name="MAC : PRACH Configuration Index" type="Integer" default="14" max="14" min="3" />
                        <variable key="MAC-NR-PERIODIC-BSR-TTI" name="MAC : Periodic BSR Timer (TTI)" type="Integer" default="1" min="1" />
                        <variable key="MAC-NR-GNB-SCHEDULER-TYPE" name="MAC : gNB Scheduler Type" type="Selection" default="ROUND-ROBIN">
                          <option value="ROUND-ROBIN" name="Round Robin" />
                          <option value="PROPORTIONAL-FAIRNESS" name="Proportional Fairness" />
                        </variable>
                        <variable key="MAC-NR-TRANSMISSION-MODE" name="MAC : Transmission Mode" type="Selection" default="1">
                          <option value="1" name="Single Antenna Scheme" />
                          <option value="2" name="Transmission Diversity (SFBC)" />
                          <option value="3" name="Transmission Diversity / Open Loop Spatial Multiplexing" />
                        </variable>
                        <variable key="MAC-NR-PF-FILTER-COEFFICIENT" name="MAC : PF Filter Coefficient" help="Exponential moving average coefficient for instant datarate" type="Fixed" default="36" min="0.0" />
                        <variable key="MAC-NR-PF-UL-RB-ALLOCATION-UNIT" name="MAC : PF Scheduler UL RB Allocation Unit" help="Resource block allocation unit for UL PF scheduling" type="Integer" default="1" max="100" min="1" />
                        <variable key="MAC-NR-MAX-HARQ-TX" name="MAC : Maximum Number of HARQ Transmissions" help="Maximum number of HARQ transmissions including first-transmission" type="Integer" default="4" max="4" min="1" />
                    </option>
                    <option value="UE" name="User Equipment">
                        <variable key="RRC-NR-WAIT-RRC-CONNECTED-TIME" name="RRC : Wait Time before RRC Connected Status" type="Time" default="10MS"  visibilityrequires="[MAC-NR-MODE]=='NSA'" refreshtable="true"/>
                        <variable key="RRC-NR-WAIT-RRC-CONNECTED-TIME" name="RRC : Wait Time before RRC Connected Status" type="Time" default="100MS" min="40MS" visibilityrequires="[MAC-NR-MODE]=='SA'" refreshtable="true"/>
                        <variable key="RRC-NR-WAIT-RRC-CONNECTED-RECONF-TIME" name="RRC : Wait Time before RRC Reconfiguration" type="Time" default="10MS"/>
                        <variable key="MAC-NR-ENABLE-WIFI-SWITCHOVER" name="Enable Switch-overs between 5G and Wi-Fi" type="Selection" default="NO" visibilityrequires="[MAC-NR-MODE]=='SA'" refreshtable="true">
                            <option value="YES" name="Yes">
                                <variable key="MAC-NR-SWITCH-CNTRL-HYSTERESIS-DELAY" name="Minimum Time between 5G/Wi-Fi Switch-overs" type="Time" default="1S" />
                            </option>
                            <option value="NO" name="No" />
                        </variable>
                        <variable key="MAC-NR-UE-SCHEDULER-TYPE" name="MAC : UE Scheduler Type" type="Selection" default="SIMPLE-SCHEDULER">
                          <option value="SIMPLE-SCHEDULER" name="Simple Scheduler"/>
                        </variable>
                    </option>
                </variable>

                <!-- Subnet-wide parameters -->
                <variable key="DUMMY-NR-SPECIFY-MEASUREMENT-PARAMETERS" name="Specify Measurement Parameters" type="Selection" default="NO" invisible="device,interface">
                <option value="YES" name="Yes">
                    <variable name="RRC : Events for RSRP Metric Handover Report" key="RRC-NR-MEAS-OBSERVING-EVENT-MASK-RSRP" type="Selection" default="00000" help="A digit means an event type (from left to right, A1, A2, ..., A5.) Specify events as '1' observed by measurement function in RSRP metric." invisible="interface,device">
                        <option value="00000" name="No Events Observed" />
                        <option value="00100" name="Observe A3 Event" />
                    </variable>
                    <variable name="RRC : Events for RSRQ Metric Handover Report" key="RRC-NR-MEAS-OBSERVING-EVENT-MASK-RSRQ" type="Selection" default="00000" help="A digit means an event type (from left to right, A1, A2, ..., A5.) Specify events as '1' observed by measurement function in RSRQ metric." invisible="interface,device">
                        <option value="00000" name="No Events Observed" />
                        <option value="00100" name="Observe A3 Event" />
                    </variable>

                    <!-- "Event A1", "Event A2", "Event A4" and "Event A5" should not be shown in GUI because these configuration parameters are disabled for future use.-->
                    <!--"Event A1"-->
                    <variable name="RRC : Threshold of Event A1 (RSRP) (dBm)" key="RRC-NR-MEAS-EVENT-A1-RSRP-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A1 (RSRP) (dB)" key="RRC-NR-MEAS-EVENT-A1-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold of Event A1 (RSRQ) (dBm)" key="RRC-NR-MEAS-EVENT-A1-RSRQ-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A1 (RSRQ) (dB)" key="RRC-NR-MEAS-EVENT-A1-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <!--"Event A2"-->
                    <variable name="RRC : Threshold of Event A2 (RSRP) (dBm)" key="RRC-NR-MEAS-EVENT-A2-RSRP-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A2 (RSRP) (dB)" key="RRC-NR-MEAS-EVENT-A2-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold of Event A2 (RSRQ) (dBm)" key="RRC-NR-MEAS-EVENT-A2-RSRQ-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A2 (RSRQ) (dB)" key="RRC-NR-MEAS-EVENT-A2-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <!--Only "Event A3" is enabled-->
                    <variable name="RRC : Offset of Event A3 (RSRP) (dB)" key="RRC-NR-MEAS-EVENT-A3-RSRP-OFF" type="Fixed" default="0.0" min="-1000" max="1000"  invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A3 (RSRP) (dB)" key="RRC-NR-MEAS-EVENT-A3-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000"  invisible="interface,device"/>
                    <variable name="RRC : Offset of Event A3 (RSRQ) (dB)" key="RRC-NR-MEAS-EVENT-A3-RSRQ-OFF" type="Fixed" default="0.0" min="-1000" max="1000"  invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A3 (RSRQ) (dB)" key="RRC-NR-MEAS-EVENT-A3-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000"  invisible="interface,device"/>
                    <!--"Event A4"-->
                    <variable name="RRC : Threshold of Event A4 (RSRP) (dBm)" key="RRC-NR-MEAS-EVENT-A4-RSRP-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A4 (RSRP) (dB)" key="RRC-NR-MEAS-EVENT-A4-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold of Event A4 (RSRQ) (dBm)" key="RRC-NR-MEAS-EVENT-A4-RSRQ-TH" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A4 (RSRQ) (dB)" key="RRC-NR-MEAS-EVENT-A4-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <!--"Event A5"-->
                    <variable name="RRC : Threshold1 of Event A5 (RSRP) (dBm)" key="RRC-NR-MEAS-EVENT-A5-RSRP-TH1" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold2 of Event A5 (RSRP) (dBm)" key="RRC-NR-MEAS-EVENT-A5-RSRP-TH2" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A5 (RSRP) (dB)" key="RRC-NR-MEAS-EVENT-A5-RSRP-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold1 of Event A5 (RSRQ) (dBm)" key="RRC-NR-MEAS-EVENT-A5-RSRQ-TH1" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Threshold2 of Event A5 (RSRQ) (dBm)" key="RRC-NR-MEAS-EVENT-A5-RSRQ-TH2" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Hysteresis of Event A5 (RSRQ) (dB)" key="RRC-NR-MEAS-EVENT-A5-RSRQ-HYS" type="Fixed" default="0.0" min="-1000" max="1000" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Time to Trigger Measurement Report Process" key="RRC-NR-MEAS-TIME-TO-TRIGGER" type="Time" default="400MS" visibilityrequires="false" keyvisible="true" invisible="interface,device"/>
                    <variable name="RRC : Periodic Measurement Report Interval" key="RRC-NR-MEAS-REPORT-INTERVAL" type="Time" default="120MS" invisible="interface,device"/>
                    <variable name="RRC : Number of Measurement Reports Sent" key="RRC-NR-MEAS-REPORT-AMOUNT" type="Integer" default="1" min="1" invisible="interface,device"/>
                    <variable name="RRC : Coefficient of Filter Measured RSRP Value" key="RRC-NR-MEAS-QUANTITY-CONFIG-FILTER-COEF-RSRP" type="Integer" default="4" min="0" max="100" invisible="interface,device"/>
                    <variable name="RRC : Coefficient of Filter Measured RSRQ Value" key="RRC-NR-MEAS-QUANTITY-CONFIG-FILTER-COEF-RSRQ" type="Integer" default="4" min="0" max="100" invisible="interface,device"/>
                    <variable name="RRC : Type of Measurement Gap" key="RRC-NR-MEAS-GAP-CONFIG-TYPE" type="Selection" default="0" help="Frequency of Inter-freq Measurement Is Determined by This Value." invisible="interface,device">
                        <option value="0" name="Every 40 subframes" />
                        <option value="1" name="Every 80 subframes" />
                    </variable>
                    <variable name="RRC : Subframe Offset of Inter-freq Measurement" key="RRC-NR-MEAS-GAP-CONFIG-OFFSET" type="Integer" default="0" min="0" visibilityrequires="false" keyvisible="true"  invisible="interface,device"/>
                </option>
                    <option value="NO" name="No" />
                </variable>
            </option>

            <option value="ANE" name="Abstract Network Equation (ANE) Satellite" addon="wireless" >
                <variable name="Satellite Architecture" key="ANESAT-SATELLITE-ARCHITECTURE" type="Selection" default="ProcessPayload">
                    <option value="BentPipe" name="Bent Pipe"/>
                    <option value="ProcessPayload" name="Processor Payload"/>
                </variable>
                <variable type="Integer" default="0" key="ANESAT-UPLINK-CHANNEL" name="Uplink Channel"></variable>
                <variable type="Text" default="DefaultUpstreamGroup" key="ANESAT-UPSTREAM-GROUP" name="Upstream Channel Group"></variable>
                <variable key="ANESAT-UPSTREAM-COUNT" name="Channel Count" type="Array" default="1" >
                    <variable key="ANESAT-UPSTREAM-BANDWIDTH" name="Upstream Bandwidth" type="Fixed multiplier" default="1000000 bps" unit="bps" maxunit="Ebps" minunit="bps" />
                    <variable type="Time" default="0.04S" key="ANESAT-UPSTREAM-MAC-LATENCY" name="Upstream MAC Latency" />
                </variable>
                <variable type="Selection" default="NONE" key="ANESAT-UPSTREAM-TRAFFIC-CONDITIONING-TYPE" name="Upstream Traffic Conditioner Type">
                    <option value="NONE" name="None"/>
                    <option value="RESIDUAL" name="Residual">
                        <variable key="ANESAT-UPSTREAM-BANDWIDTH-LIMIT" name="Upstream Bandwidth Limit" type="Fixed multiplier" default="512000 bps" unit="bps" maxunit="Ebps" minunit="bps" />
                        <variable key="ANESAT-UPSTREAM-BANDWIDTH-MINIMUM" name="Upstream Bandwidth Minimum" type="Fixed multiplier" default="64000 bps" unit="bps" maxunit="Ebps" minunit="bps" />
                    </option>
                    <option value="STRICT" name="Strict">
                        <variable key="ANESAT-UPSTREAM-BANDWIDTH-LIMIT" name="Upstream Bandwidth Limit" type="Fixed multiplier" default="512000 bps" unit="bps" maxunit="Ebps" minunit="bps" />
                    </option>
                </variable>
                <variable key="ANESAT-DOWNSTREAM-BANDWIDTH" name="Downstream Bandwidth" type="Fixed multiplier" default="70000000 bps" unit="bps" maxunit="Ebps" minunit="bps" ></variable>
                <variable type="Time" default="5MS" key="ANESAT-DOWNSTREAM-MAC-LATENCY" name="Downstream MAC Latency"></variable>
                <variable type="Text" default="Downstream0" key="ANESAT-CHANNEL-ID" name="Anesat Subnet Channel Identifier"></variable>
                <variable type="Selection" default="ane_default_mac" key="ANE-EQUATION-DEFINITION" name="Equation Definition File/class" invisible="interface">
                    <option value="anesat_mac" name="Abstract Multichannel Satellite"></option>
                    <option value="ane_default_mac" name="Abstract Base Satellite"></option>
                </variable>
                <variable type="Selection" default="Asymmetric" key="ANE-SUBNET-ARCHITECTURE" name="Subnet Topology" invisible="interface">
                    <option value="Asymmetric" name="Host to Gateway">
                        <variable type="Integer" default="[Required]" key="ANE-HEADEND-NODE" name="Headend Node" invisible="interface" min = "1"></variable>
                    </option>
                    <option value="Symmetric" name="Host to Host">
                    </option>
                </variable>
                <variable type="Integer" default="1" key="ANE-PROCESSOR-NODE" name="ANE Simulation Processing Node" help="Centralized processing node" invisible="interface"/>
                <variable type="Integer" default="0" key="ANE-PROCESSOR-NODE-INDEX" name="ANE Simulation Node Index" help="Centralized processing node index" invisible="interface" />

            </option>
            <option value="SATELLITE-BENTPIPE" name="Satellite-RSV MAC" addon="wireless" >
                <variable name="Protocol Role" key="MAC-SATELLITE-BENTPIPE-ROLE" type="Selection" default="GROUND-STATION" prepend="id" issatellitekey="yes" >
                    <option value="SATELLITE" name="Satellite">
                        <variable name="No. of Satellite Channels" key="MAC-SATELLITE-CHANNEL-COUNT" default="1" type="Array">
                        <variable name="Satellite Uplink Channel" key="MAC-SATELLITE-UPLINK-CHANNEL" default="[Required]" type="Text"/>
                        <variable name="Satellite Downlink Channel" key="MAC-SATELLITE-DOWNLINK-CHANNEL" default="[Required]" type="Text"/>
                        </variable>
                    </option>
                    <option value="GROUND-STATION" name="Ground Station">
                        <variable name="Use Uplink Channel" key="MAC-SATELLITE-USE-UPLINK-CHANNEL" default="[Required]" type="Text" invisible="WirelessSubnet"/>
                        <variable name="Use Downlink Channel" key="MAC-SATELLITE-USE-DOWNLINK-CHANNEL" default="[Required]" type="Text" invisible="WirelessSubnet"/>
                        <variable name="Use Uplink Channel" key="DUMMY-MAC-SATELLITE-USE-UPLINK-CHANNEL" default="Configure at each Ground Station's interface to the satellite" type="Text" disable="true" dontWriteToConfig="true" invisible="interface"/>
                        <variable name="Use Downlink Channel" key="DUMMY-MAC-SATELLITE-USE-DOWNLINK-CHANNEL" default="Configure at each Ground station's interface to the satellite" type="Text" disable="true" dontWriteToConfig="true" invisible="interface"/>
                    </option>
                </variable>
                <variable name="Forward to Payload Processor" key="MAC-SATELLITE-BENTPIPE-FORWARD-TO-PAYLOAD-PROCESSOR" type="Selection" default="NO" prepend="id">
                    <option value="YES" name="Yes" />
                    <option value="NO" name="No" />
                </variable>
                <variable name="Frame Transmit Power (mW)" help="mW" key="MAC-SATELLITE-BENTPIPE-TRANSMIT-POWER-MW" type="Fixed" default="3000.0" min="0.0" prepend="id" />
            </option>
            <option value="CSMA" name="CSMA" addon="wireless"  visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'"/>
            <option value="MACA" name="MACA" addon="wireless"  visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'"/>
            <option value="FCSC-CSMA" name="FCSC-CSMA" addon="military"  visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'"/>
            <option value="TDMA" name="TDMA" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Slot Duration" key="TDMA-SLOT-DURATION" type="Time" default="10MS" help="TDMA slot duration must be greater than or equal to 1MS and less than or equal to 1S. The default value is 10MS. This duration should be longer enough so that a packet can be transmitted." />
                <variable name="Guard Time" key="TDMA-GUARD-TIME" type="Time" default="0NS" />
                <variable name="Inter-frame Time" key="TDMA-INTER-FRAME-TIME" type="Time" default="1US" />
                <variable name="Scheduling" key="TDMA-SCHEDULING" type="Selection" default="AUTOMATIC">
                    <option value="AUTOMATIC" name="Automatic" />
                    <option value="FILE" name="File">
                        <variable name="Scheduling File" key="TDMA-SCHEDULING-FILE" type="File" default="[Required]" />
                    </option>
                </variable>
                <variable name="Slots per Frame" key="TDMA-NUM-SLOTS-PER-FRAME" type="Integer" optional="true" default="30" help="By default, if no TDMA schedule is given, this is set to the number of nodes in the network. If a schedule is given, by default, this is set to the number of slots necessary for the schedule. If this parameter value is given, it must be at least as large as the aforementioned default values or an error will be produced. In addition, the number of slots per frame must be greater than 0 and less than or equal to 2000." />
            </option>
            <option value="TDMA-HEATMAP" name="TDMA HEATMAP" addon="wireless" visibilityrequires="false">
                <variable name="Slot Duration" key="TDMA-HEATMAP-SLOT-DURATION" type="Time" default="10MS" help="TDMA slot duration must be greater than or equal to 1MS and less than or equal to 1S. The default value is 10MS. This duration should be longer enough so that a packet can be transmitted." />
                <variable name="Guard Time" key="TDMA-HEATMAP-GUARD-TIME" type="Time" default="0NS" />
                <variable name="Inter-frame Time" key="TDMA-HEATMAP-INTER-FRAME-TIME" type="Time" default="1US" />
                <variable name="Scheduling" key="TDMA-HEATMAP-SCHEDULING" type="Selection" default="AUTOMATIC">
                    <option value="AUTOMATIC" name="Automatic" />
                    <option value="FILE" name="File">
                        <variable name="Scheduling File" key="TDMA-HEATMAP-SCHEDULING-FILE" type="File" default="[Required]" />
                    </option>
                </variable>
                <variable name="Slots per Frame" key="TDMA-HEATMAP-NUM-SLOTS-PER-FRAME" type="Integer" optional="true" default="30" help="By default, if no TDMA schedule is given, this is set to the number of nodes in the network. If a schedule is given, by default, this is set to the number of slots necessary for the schedule. If this parameter value is given, it must be at least as large as the aforementioned default values or an error will be produced. In addition, the number of slots per frame must be greater than 0 and less than or equal to 2000." />
            </option>

            <option value="TDMA-USAP" name="TDMA USAP" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Guard Time" key="TDMA-USAP-GUARD-TIME" type="Time" default="0NS" />
                <variable name="Inter-frame Time" key="TDMA-USAP-INTER-FRAME-TIME" type="Time" default="1US" />
                <variable name="Scheduling" key="TDMA-USAP-SCHEDULING" type="Selection" default="AUTOMATIC">
                    <option value="AUTOMATIC" name="Automatic" />
                    <option value="FILE" name="File">
                        <variable name="Scheduling File" key="TDMA-USAP-SCHEDULING-FILE" type="File" default="[Required]" />
                    </option>
                </variable>
                <variable name="Slots per Frame" key="TDMA-USAP-NUM-SLOTS-PER-FRAME" type="Integer" optional="true" default="1536" help="By default, if no TDMA-USAP schedule is given, this is set to the number of nodes in the network. If a schedule is given, by default, this is set to the number of slots necessary for the schedule. If this parameter value is given, it must be at least as large as the aforementioned default values or an error will be produced. In addition, the number of slots per frame must be greater than 0 and less than or equal to 2000." />
		        <variable name="Slot Duration" key="TDMA-USAP-SLOT-DURATION" type="Time" default="7.8125MS" help="TDMA-USAP slot duration must be greater than or equal to 1MS and less than or equal to 1S. The default value is 10MS. This duration should be longer enough so that a packet can be transmitted." />
            </option>

            <option value="TDMA-USAP-HEATMAP" name="TDMA-USAP HEATMAP" addon="wireless" visibilityrequires="false">
                <variable name="Slot Duration" key="TDMA-USAP-HEATMAP-SLOT-DURATION" type="Time" default="7.8125MS" help="TDMA-USAP slot duration must be greater than or equal to 1MS and less than or equal to 1S. The default value is 10MS. This duration should be longer enough so that a packet can be transmitted." />
                <variable name="Guard Time" key="TDMA-USAP-HEATMAP-GUARD-TIME" type="Time" default="0NS" />
                <variable name="Inter-frame Time" key="TDMA-USAP-HEATMAP-INTER-FRAME-TIME" type="Time" default="1US" />
                <variable name="Scheduling" key="TDMA-USAP-HEATMAP-SCHEDULING" type="Selection" default="AUTOMATIC">
                    <option value="AUTOMATIC" name="Automatic" />
                    <option value="FILE" name="File">
                        <variable name="Scheduling File" key="TDMA-USAP-HEATMAP-SCHEDULING-FILE" type="File" default="[Required]" />
                    </option>
                </variable>
                <variable name="Slots per Frame" key="TDMA-USAP-HEATMAP-NUM-SLOTS-PER-FRAME" type="Integer" optional="true" default="30" help="By default, if no TDMA-USAP schedule is given, this is set to the number of nodes in the network. If a schedule is given, by default, this is set to the number of slots necessary for the schedule. If this parameter value is given, it must be at least as large as the aforementioned default values or an error will be produced. In addition, the number of slots per frame must be greater than 0 and less than or equal to 2000." />
            </option>
			<option value="TDMA-URAP" name="TDMA URAP" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
				<variable name="Guard Time" key="TDMA-URAP-GUARD-TIME" type="Time" default="0NS" />
				<variable name="Inter-frame Time" key="TDMA-URAP-INTER-FRAME-TIME" type="Time" default="1US" />
				<variable name="Scheduling" key="TDMA-URAP-SCHEDULING" type="Selection" default="AUTOMATIC">
					<option value="AUTOMATIC" name="Automatic" />
					<option value="FILE" name="File">
						<variable name="8 Nodes Network Scheduling File" key="TDMA-URAP-SCHEDULING-8-FILE" type="File" default="[Required]" />
						<variable name="16 Nodes Network Scheduling File" key="TDMA-URAP-SCHEDULING-16-FILE" type="File" default="[Required]" />
						<variable name="32 Nodes Network Scheduling File" key="TDMA-URAP-SCHEDULING-32-FILE" type="File" default="[Required]" />
						<variable name="64 Nodes Network Scheduling File" key="TDMA-URAP-SCHEDULING-64-FILE" type="File" default="[Required]" />
						<variable name="128 Nodes Network Scheduling File" key="TDMA-URAP-SCHEDULING-128-FILE" type="File" default="[Required]" />
					</option>
				</variable>

				<variable name="Slots per Frame" key="TDMA-URAP-NUM-SLOTS-PER-FRAME" type="Integer" optional="true" default="1536" help="By default, if no TDMA-URAP schedule is given, this is set to the number of nodes in the network. If a schedule is given, by default, this is set to the number of slots necessary for the schedule. If this parameter value is given, it must be at least as large as the aforementioned default values or an error will be produced. In addition, the number of slots per frame must be greater than 0 and less than or equal to 2000." />
				<variable name="Slot Duration" key="TDMA-URAP-SLOT-DURATION" type="Time" default="5MS" help="TDMA-URAP slot duration must be greater than or equal to 1MS and less than or equal to 1S. The default value is 10MS. This duration should be longer enough so that a packet can be transmitted." />
			</option>

			<option value="TDMA-URAP-HEATMAP" name="TDMA-URAP HEATMAP" addon="wireless" visibilityrequires="false">
				<variable name="Slot Duration" key="TDMA-URAP-HEATMAP-SLOT-DURATION" type="Time" default="5MS" help="TDMA-URAP slot duration must be greater than or equal to 1MS and less than or equal to 1S. The default value is 10MS. This duration should be longer enough so that a packet can be transmitted." />
				<variable name="Guard Time" key="TDMA-URAP-HEATMAP-GUARD-TIME" type="Time" default="0NS" />
				<variable name="Inter-frame Time" key="TDMA-URAP-HEATMAP-INTER-FRAME-TIME" type="Time" default="1US" />
				<variable name="Scheduling" key="TDMA-URAP-HEATMAP-SCHEDULING" type="Selection" default="AUTOMATIC">
					<option value="AUTOMATIC" name="Automatic" />
					<option value="FILE" name="File">
						<variable name="Scheduling File 64 Nodes" key="TDMA-URAP-HEATMAP-SCHEDULING-FILE" type="File" default="[Required]" />
						<variable name="Scheduling File 128 Nodes" key="TDMA-URAP-HEATMAP-SCHEDULING-FILE-128-NODES" type="File" default="[Required]" />
					</option>
				</variable>
				<variable name="Slots per Frame" key="TDMA-URAP-HEATMAP-NUM-SLOTS-PER-FRAME" type="Integer" optional="true" default="30" help="By default, if no TDMA-URAP schedule is given, this is set to the number of nodes in the network. If a schedule is given, by default, this is set to the number of slots necessary for the schedule. If this parameter value is given, it must be at least as large as the aforementioned default values or an error will be produced. In addition, the number of slots per frame must be greater than 0 and less than or equal to 2000." />
			</option>

            <option value="ALOHA" name="Aloha" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'"/>
            <option value="SPMA" name="Spma" addon="wireless" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'"/>
            <option value="MAC-LINK-16" name="Link 16" addon="military" invisible="WiredSubnet, interface" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Link 16 Data Packing Scheme" key="LINK-16-DATA-PACKING-SCHEME" type="Selection" default="STD-DP" >
                    <option value="STD-DP" name="STD-DP" />
                    <option value="P2SP" name="P2SP" />
                    <option value="P2DP" name="P2DP" />
                    <option value="P4SP" name="P4SP" />
                </variable>
                <variable name="Link 16 Encoding" key="LINK-16-ENCODING-SCHEME" type="Checkbox" default="NO" />
                        <variable name="Link 16 Code Length" key="LINK-16-CODE-LENGTH" type="Integer" default="1" />
                        <variable name="Link 16 Data Length" key="LINK-16-DATA-LENGTH" type="Integer" default="1" />
                <variable name="Link 16 Time Slot Allocation File" key="LINK-16-SLOT-FILE" type="SlotFile" default="[Required]" filetype="slot" invisible="device,interface" />
                <variable name="Open NPG Editor" key="LINK-16-NPG-EDITOR" type="NPGEditor" default="" keyvisible="false" invisible="device,interface" />
                <variable name="Maximum NPG Index" key="MAX-NPG-INDEX" type="Integer" default="512" invisible="device,interface" />
            </option>
            <option value="MAC-LINK-11" name="Link 11" addon="military" invisible="WiredSubnet, interface" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Link 11 NCS Node" key="LINK-11-NCS" type="Integer" default="1" help="Please Enter the Node Id of the NCS Node for this network"/>
                <variable name="Link 11 Data Rate" key="LINK-11-DATA-RATE" type="Selection" default="FAST" help="Please Specify the Link 11 Data Rate from the given choices">
                    <option value="FAST" name="Fast Rate:2250 bps" />
                    <option value="SLOWL" name="Slowl Rate: 1364 bps" />
                    <option value="SLOWS" name="Slows Rate: 1364 bps" />
                </variable>
                <variable name="Link 11 Polling Order" key="LINK-11-POLLING-ORDER-TYPE" type="Selection" default="SERIAL" help="Please select the polling order options from the given choices ">
                    <option value="SERIAL" name="Serial" />
                    <option value="USER-SPECIFIED" name="User-Specified">
                        <variable key="LINK-11-USER-SPECIFIED-POLLING-ORDER" type="Text" name="Polling List" default="{}" optional="true" help="List the nodes which are ICMP routers between the '{}' separated by commas.  You can use 'thru' to specify a range of nodes." invisible="Device" />
                    </option>
                </variable>
                <variable name="Configure Link 11 Rx Threshold Manully" key="USER-SPECIFIED-RX-THRESHOLD" type= "Selection" default="NO">
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="Link 11 Rx Threshold" key="LINK-11-RX-SNR-THRESHOLD" type= "Fixed" default="10"/>
                    </option>
                </variable>
            </option>
            <option value="GENERICMAC" name="Generic MAC" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Channel Access Mode" key="CHANNEL-ACCESS" type="Selection" default="PSMA">
                    <option value="PSMA" name="PSMA" />
                    <option value="CSMA" name="CSMA" />
                    <option value="CSMA-CA" name="CSMA-CA" />
                    <option value="SLOT-CSMA" name="SLOT-CSMA">
                        <variable name="Slot Duration" key="SLOT" type="Time" default="10MS" help="GENERICMAC slot duration must be greater than or equal to 1MS and less than or equal to 1S. The default value is 10MS. This duration should be longer enough so that a packet can be transmitted." />
                    </option>
                    <option value="SLOT-CSMA-CA" name="SLOT-CSMA-CA">
                        <variable name="Slot Duration" key="SLOT" type="Time" default="10MS" help="GENERICMAC slot duration must be greater than or equal to 1MS and less than or equal to 1S. The default value is 10MS. This duration should be longer enough so that a packet can be transmitted." />
                    </option>
                </variable>
                <variable name="Enable RTS/CTS" key="RTS-CTS" type="Checkbox" default="NO" />
                <variable name="Enable ACK" key="ACK" type="Checkbox" default="NO" />
                <variable name="Retry Limit" key="RETRY-LIMIT" type="Integer" default="25" min="0"/>
            </option>

            <option value="MAC-WORMHOLE" name="Wormhole" addon="cyber" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRELESS'">
                <variable name="Wormhole Operation Mode" key="WORMHOLE-MODE" type="Selection" default="THRESHOLD">
                    <option value="THRESHOLD" name="Threshold">
                        <variable name="Wormhole Link Drop Threshold" key="WORMHOLE-THRESHOLD" type="Integer" default="150" />
                    </option>
                    <option value="ALLPASS" name="All Pass"/>
                    <option value="ALLDROP" name="All Drop"/>
                </variable>
                <variable name="Wormhole Link Bandwidth (bits/second)" key="WORMHOLE-LINK-BANDWIDTH" type="Fixed multiplier" default="10000000 bps" unit="bps" maxunit="Ebps" minunit="bps"/>
                <variable name="Wormhole Replay Mac Protocol" key="WORMHOLE-REPLAY-MAC-PROTOCOL" type="Text" default="WORMHOLE-CSMA" disable="true" />
                <variable name="Wormhole Propagation Delay" key="WORMHOLE-PROPAGATION-DELAY" type="Time" default="1US" />
                <variable name="Specify Wormhole Victim Turnaround Time" key="WORMHOLE-VICTIM-COUNT-TURNAROUND-TIME" type="Selection" default="NO" >
                    <option value="NO" name="No" />
                    <option value="YES" name="Yes">
                        <variable name="Wormhole Victim Turnaround Time" key="WORMHOLE-VICTIM-TURNAROUND-TIME" type="Time" default="0MS" />
                    </option>
                </variable>
            </option>
        </variable>
        <variable name="MAC Propagation Delay" key="MAC-PROPAGATION-DELAY" type="Time" default="1US" help="specifies an additional delay for messages sent by the MAC layer to the phy layer.  Some MAC protocols use a multiple of this value." addon="wireless" visibilityrequires="[MAC-PROTOCOL] != 'None'  &amp;&amp; [MAC-PROTOCOL] != 'SATELLITE-BENTPIPE' &amp;&amp; [MAC-PROTOCOL] != 'ANE' &amp;&amp; [MAC-PROTOCOL] != 'SATCOM' &amp;&amp; [DUMMY-INTERFACE-TYPE] != 'LINK-WIRED'"/>
        <variable name="Enable Promiscuous Mode" key="PROMISCUOUS-MODE" type="Checkbox" default="NO" optional="true" visibilityrequires="[MAC-PROTOCOL] != 'MAC-BT-CLASSIC' &amp;&amp; [MAC-PROTOCOL] != 'MAC-BT-LE'" help="must be set to YES if nodes want to overhear packets destined to the neighboring node." />
        <variable name="Enable LLC" key="LLC-ENABLED" type="Selection" default="NO" visibilityrequires="[MAC-PROTOCOL] != 'MAC-BT-CLASSIC' &amp;&amp; [MAC-PROTOCOL] != 'MAC-BT-LE'" invisible="device, ScenarioLevel">
            <option value="NO" name="No"/>
            <option value="YES" name="Yes">
                <variable name="Enable SNAP" key="SNAP-ENABLED" type="Checkbox" default="YES" invisible="device, ScenarioLevel" />
            </option>
        </variable>
        <variable name="Configure MAC Address" key="DUMMY-MAC-ADDRESS" help="ARP must be enabled to configure MAC address." type="Selection" default="NO" optional="true" invisible="ScenarioLevel, Device, WirelessSubnet">
            <option value="NO" name="No"></option>
            <option value="YES" name="Yes" >
                <variable name="Read MAC Address from File" key="DUMMY-ADDRESS-FROM-FILE" type="Selection" default="NO" keyvisible="false" >
                    <option name="Yes" value="YES">
                        <variable name="MAC Address Configuration File" key="MAC-ADDRESS-CONFIG-FILE" type="File" default="[Required]" filetype="mac-address"/>
                    </option>
                    <option name="No" value="NO">
                        <variable name="MAC Address Type" key="MAC-ADDRESS-TYPE" type="Selection" default="ETHERNET">
                            <option value="ETHERNET" name="Ethernet"/>
                            <option value="ATM" name="ATM"/>
                        </variable>
                        <variable name="MAC Address Value" key="MAC-ADDRESS" type="Text" default="[Required]"/>
                        <variable name="MAC Address Length" key="MAC-ADDRESS-LENGTH" type="Integer" default="6" disable="true"/>
                    </option>
                </variable>
            </option>
        </variable>
        <variable key="SWITCH-STATION-VLAN-TAGGING" type="Selection" name="Use Station VLAN Tagging" default="NO" optional="true" visibilityrequires="[DUMMY-INTERFACE-TYPE] == 'LINK-WIRED' || [DUMMY-INTERFACE-TYPE] == 'LINK-WIRELESS' || [DUMMY-INTERFACE-TYPE] == 'LINK-MICROWAVE' || [DUMMY-INTERFACE-TYPE] == 'SUBNET-WIRED'" >
            <option value="NO" name="No" />
            <option value="YES" name="Yes" >
                <variable key="SWITCH-STATION-VLAN-ID" type="Integer" name="Station VLAN ID" default="1" min="0" max="4090" />
            </option>
        </variable>
    </subcategory>
</category>
